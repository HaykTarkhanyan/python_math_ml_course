{
  "permissions": {
    "allow": [
      "Bash(pdflatex:*)",
      "Bash(sort:*)",
      "Skill(beamer-overflow-check)",
      "Skill(generate-solutions)",
      "Bash(rm -f 10_stat.aux 10_stat.log 10_stat.nav 10_stat.out 10_stat.snm 10_stat.toc)",
      "Bash(rm -rf /tmp/beamer_check)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'TOOL_INPUT=$(cat); CMD=$(echo \"$TOOL_INPUT\" | grep -o \"pdflatex[^\\\"]*\" 2>/dev/null); if [ -n \"$CMD\" ]; then PDF=$(echo \"$CMD\" | sed \"s/pdflatex.*\\s\\+//; s/\\.tex/.pdf/\"); echo \"Compiled. Run /beamer-overflow-check on the output PDF to check for clipped content.\"; fi'"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-qmd.sh\""
          }
        ]
      }
    ]
  }
}
