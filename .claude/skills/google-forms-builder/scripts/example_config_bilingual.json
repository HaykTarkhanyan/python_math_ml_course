{
  "csv_path": "math_understanding_test.csv",
  "output_path": "build_form.gs",
  "form_title": "Math Understanding Test",
  "form_description": "A self-assessment of your math intuition. Pick one answer. After submitting you will see the correct answer and an explanation.",
  "is_quiz": true,
  "number_questions": true,
  "joins": {"question": "\n", "option": " / ", "feedback": "\n\n"},
  "columns": {
    "question": ["question_hy", "question_en"],
    "options": [
      ["optA_hy", "optA_en"],
      ["optB_hy", "optB_en"],
      ["optC_hy", "optC_en"],
      ["optD_hy", "optD_en"]
    ],
    "correct": "correct",
    "points": "points",
    "feedback_correct": ["feedback_correct_hy", "feedback_correct_en"],
    "feedback_wrong": ["feedback_wrong_hy", "feedback_wrong_en"]
  },
  "section_column": "area",
  "section_titles": {
    "preliminaries": "Preliminaries",
    "linear_algebra": "Linear Algebra"
  }
}
