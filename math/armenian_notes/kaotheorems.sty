\usetikzlibrary{shapes,calc}
\tcbuselibrary{skins}
\newcommand{\readings}{babyblueeyes!35!white}

\newtcbox{\titlebox}{
    enhanced,
    overlay={
        \draw[\readings,fill=\readings](frame.south east)--+(0,.2)to[bend right]+(.2,-0)--cycle;},
        colback=\readings,
        top=-1pt,bottom=-2pt,left=2pt,right=2pt,
        boxrule=1pt,
        colframe=\readings,
        sharp corners=south,
        colupper=black,
        fontupper=\bfseries
}

\newtcolorbox{myblock}[1][]{
    enhanced,
    left=2pt,
    right=2pt,
    colframe=\readings,
    boxrule=1pt,
    colback=\readings,
    overlay={
        \def\myblock@tempa{#1}
        \ifx\myblock@tempa\@empty
        \else
        \draw[\readings,fill=\readings]($(frame.north west)+(.2pt,-.2pt)$)--+(.1,0)to[bend right]+(-0,-.1)--cycle;
        \node [
            anchor=south west,
            inner sep=0pt,
            outer sep=0pt
        ]at(frame.north west){\titlebox{#1}};
    \fi
    },
}


