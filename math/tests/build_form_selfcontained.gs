var ROWS = [{"id": "PRE-01", "area": "preliminaries", "module": "00", "difficulty": "1", "template": "misconception", "question_hy": "f: X -> Y ֆունկցիան կոչվում է ինյեկտիվ, երբ...", "question_en": "A function f: X -> Y is called injective (one-to-one) when...", "optA_hy": "Y-ի յուրաքանչյուր տարր ստացվում է ինչ-որ x-ից", "optA_en": "every element of Y is hit by some x", "optB_hy": "տարբեր մուտքերը միշտ տալիս են տարբեր ելքեր", "optB_en": "different inputs always give different outputs", "optC_hy": "յուրաքանչյուր մուտք ունի ուղիղ մեկ ելք", "optC_en": "every input has exactly one output", "optD_hy": "այն ունի հակադարձ ֆունկցիա ամբողջ Y-ի վրա", "optD_en": "it has an inverse defined on all of Y", "correct": "B", "points": "1", "feedback_correct_hy": "Ինյեկտիվ = ոչ մի երկու մուտք չունեն նույն ելքը. f(a)=f(b)-ից հետևում է a=b.", "feedback_correct_en": "Injective = no two inputs share an output. f(a)=f(b) implies a=b.", "feedback_wrong_hy": "A-ն սյուրյեկտիվության (վրա) սահմանումն է; C-ն ուղղակի ֆունկցիա լինելու պայմանն է; D-ն բիյեկտիվությունն է. Ինյեկտիվությունը միայն արգելում է երկու մուտքի նույն ելք ունենալը.", "feedback_wrong_en": "A defines surjective (onto); C is just what makes something a function; D is bijective. Injective only forbids two inputs mapping to the same output."}, {"id": "PRE-02", "area": "preliminaries", "module": "00", "difficulty": "2", "template": "compare", "question_hy": "10 ուսանողից ընտրում ես 3-ին՝ կոմիտե կազմելու համար (առանց դերերի): Համեմատած 3 ուսանող որոշակի դերերով ընտրելու հետ (նախագահ, քարտուղար, գանձապահ)՝ կոմիտեների քանակը...", "question_en": "You pick 3 of 10 students to form a committee (no roles). Compared with picking 3 students for distinct roles (president, secretary, treasurer), the number of committees is...", "optA_hy": "ավելի մեծ է", "optA_en": "larger", "optB_hy": "նույնն է", "optB_en": "the same", "optC_hy": "ավելի փոքր է՝ 3! = 6 անգամ", "optC_en": "smaller, by a factor of 3! = 6", "optD_hy": "ավելի փոքր է՝ 3 անգամ", "optD_en": "smaller, by a factor of 3", "correct": "C", "points": "1", "feedback_correct_hy": "Կոմիտեն զուգորդություն է C(10,3); դերերով ընտրությունը կարգավորություն է A(10,3) = C(10,3)*3!. Կարգն անտեսելը բաժանում է 3! = 6-ի.", "feedback_correct_en": "A committee is a combination C(10,3); assigning distinct roles is an ordered selection P(10,3) = C(10,3)*3!. Ignoring order divides by 3! = 6.", "feedback_wrong_hy": "Առանց կարգի ընտրությունը միշտ <= կարգով ընտրությունից, ուստի A և B սխալ են. Գործակիցը 3 ընտրվածների դասավորությունների քանակն է՝ 3! = 6, ոչ թե 3 (D).", "feedback_wrong_en": "Order-less selection is always <= ordered, so A and B are wrong. The factor is the number of orderings of the 3 chosen, 3! = 6, not 3 (D)."}, {"id": "LA-01", "area": "linear_algebra", "module": "01", "difficulty": "1", "template": "misconception", "question_hy": "Երկու ոչ զրոյական վեկտորների սկալյար արտադրյալը x·y = 0 է: Սա նշանակում է, որ...", "question_en": "Two nonzero vectors have dot product x·y = 0. This means...", "optA_hy": "նրանք ուղղված են հակառակ ուղղություններով", "optA_en": "they point in opposite directions", "optB_hy": "նրանք ուղղահայաց են (օրթոգոնալ)", "optB_en": "they are perpendicular (orthogonal)", "optC_hy": "նրանք գծորեն կախված են", "optC_en": "they are linearly dependent", "optD_hy": "նրանցից գոնե մեկը զրոյական վեկտոր է", "optD_en": "at least one of them is the zero vector", "correct": "B", "points": "1", "feedback_correct_hy": "Զրո սկալյար արտադրյալ = օրթոգոնալ (90 աստիճան), քանի որ cos(theta)=0.", "feedback_correct_en": "Zero dot product = orthogonal (90 degrees), since cos(theta)=0.", "feedback_wrong_hy": "Հակառակ ուղղությունները տալիս են բացասական արտադրյալ, ոչ զրո (A). Օրթոգոնալ վեկտորները գծորեն անկախ են, ոչ կախված (C). Ըստ պայմանի՝ երկուսն էլ ոչ զրոյական են (D).", "feedback_wrong_en": "Opposite directions give a negative dot product, not zero (A). Orthogonal vectors are linearly independent, not dependent (C). Both are given nonzero (D)."}, {"id": "LA-02", "area": "linear_algebra", "module": "01", "difficulty": "1", "template": "compare", "question_hy": "v = (3, 4) վեկտորի համար, առանց տասնորդական հաշվարկի՝ ինչպե՞ս են համեմատվում նրա L1 և L2 նորմերը:", "question_en": "For the vector v = (3, 4), without computing decimals: how do its L1 and L2 norms compare?", "optA_hy": "L1 = L2", "optA_en": "L1 = L2", "optB_hy": "L1 > L2", "optB_en": "L1 > L2", "optC_hy": "L1 < L2", "optC_en": "L1 < L2", "optD_hy": "հնարավոր չէ համեմատել առանց լրացուցիչ տվյալների", "optD_en": "cannot compare without more information", "correct": "B", "points": "1", "feedback_correct_hy": "L1 = |3|+|4| = 7; L2 = sqrt(9+16) = 5. Ընդհանուր դեպքում L1 >= L2.", "feedback_correct_en": "L1 = |3|+|4| = 7; L2 = sqrt(9+16) = 5. In general L1 >= L2.", "feedback_wrong_hy": "L1-ը բացարձակ արժեքների գումարն է (7), L2-ը Էվկլիդեսյան երկարությունը (5). L1 >= L2 միշտ՝ հավասար են միայն առանցքի երկայնքով վեկտորների դեպքում.", "feedback_wrong_en": "L1 is the sum of absolute values (7), L2 the Euclidean length (5). L1 >= L2 always - equal only for vectors lying along an axis."}, {"id": "LA-03", "area": "linear_algebra", "module": "02", "difficulty": "2", "template": "misconception", "question_hy": "Քառակուսի մատրիցի որոշիչը (դետերմինանտը) 0 է: Ո՞ր պնդումն է ճիշտ:", "question_en": "A square matrix has determinant 0. Which statement is correct?", "optA_hy": "Մատրիցը փոքր է, բայց դեռ հակադարձելի", "optA_en": "the matrix is small but still invertible", "optB_hy": "Մատրիցը վերասերված է (singular)՝ չունի հակադարձ", "optB_en": "the matrix is singular - it has no inverse", "optC_hy": "Մատրիցը պարտադիր զրոյական մատրից է", "optC_en": "the matrix must be the zero matrix", "optD_hy": "Նրա տողերը օրթոգոնալ են", "optD_en": "its rows are orthogonal", "correct": "B", "points": "1", "feedback_correct_hy": "det = 0 նշանակում է վերասերված (singular). սյուները գծորեն կախված են, ռանգ < n, հակադարձ չկա.", "feedback_correct_en": "det = 0 means singular: the columns are linearly dependent, rank < n, no inverse exists.", "feedback_wrong_hy": "det=0-ն չափի մասին չէ (A)՝ այն նշանակում է ոչ-հակադարձելի. Ոչ զրոյական մատրիցը նույնպես կարող է ունենալ det 0 (C). Օրթոգոնալ տողերը կտան ոչ զրոյական det (D).", "feedback_wrong_en": "det=0 is not about size (A) - it means non-invertible. A nonzero matrix can still have det 0 (C). Orthogonal rows would give a nonzero det (D)."}, {"id": "LA-04", "area": "linear_algebra", "module": "03", "difficulty": "2", "template": "misconception", "question_hy": "v-ն A մատրիցի սեփական վեկտորն է: Երկրաչափորեն սա նշանակում է, որ...", "question_en": "v is an eigenvector of matrix A. Geometrically this means...", "optA_hy": "Av-ն ուղղահայաց է v-ին", "optA_en": "Av is perpendicular to v", "optB_hy": "Av-ն գտնվում է v-ի նույն ուղղի վրա՝ A-ն միայն մասշտաբավորում է այն", "optB_en": "Av lies on the same line as v - A only scales it", "optC_hy": "Av = 0", "optC_en": "Av = 0", "optD_hy": "A-ն պտտում է v-ն 90 աստիճանով", "optD_en": "A rotates v by 90 degrees", "correct": "B", "points": "1", "feedback_correct_hy": "Սեփական վեկտոր. Av = lambda*v, այսինքն A-ն v-ն մասշտաբավորում է՝ պահպանելով ուղին.", "feedback_correct_en": "Eigenvector: Av = lambda*v, so A scales v while keeping it on the same line.", "feedback_wrong_hy": "Ուղղահայացությունը (A) և 90 աստիճան պտույտը (D) փոխում են ուղղությունը, ինչը հակասում է սեփական վեկտորի գաղափարին. Av=0 միայն եթե lambda=0, ոչ ընդհանուր դեպքում (C).", "feedback_wrong_en": "Perpendicularity (A) and a 90-degree rotation (D) change direction, contradicting the eigenvector idea. Av=0 only if lambda=0, not in general (C)."}, {"id": "LA-05", "area": "linear_algebra", "module": "03", "difficulty": "3", "template": "flaw", "question_hy": "Պնդում. «Այս 4 վեկտորները գտնվում են R^3-ում, բոլորը տարբեր են և ոչ մեկը մյուսի սկալյար բազմապատիկը չէ, ուստի նրանք գծորեն անկախ են»: Որտե՞ղ է սխալը:", "question_en": "Claim: 'These 4 vectors live in R^3, are all different, and none is a scalar multiple of another, so they are linearly independent.' Where does the reasoning break?", "optA_hy": "Տարբեր վեկտորները միշտ անկախ են՝ պնդումը ճիշտ է", "optA_en": "different vectors are always independent - the claim is fine", "optB_hy": "«Ոչ մի վեկտոր մյուսի բազմապատիկը չէ»-ն երաշխավորում է անկախություն", "optB_en": "'no vector is a multiple of another' guarantees independence", "optC_hy": "R^3-ում ցանկացած 4 վեկտոր անպայման կախված են՝ առավելագույնը 3-ը կարող են անկախ լինել", "optC_en": "any 4 vectors in R^3 are necessarily dependent - at most 3 can be independent", "optD_hy": "Անկախությունը հնարավոր չէ որոշել առանց որոշիչը հաշվելու", "optD_en": "independence cannot be decided without computing a determinant", "correct": "C", "points": "1", "feedback_correct_hy": "R^n-ում առավելագույնը n վեկտոր կարող է անկախ լինել, ուստի R^3-ում 4 վեկտոր միշտ կախված են՝ անկախ նրանից որքան տարբեր են.", "feedback_correct_en": "In R^n at most n vectors can be independent, so 4 vectors in R^3 are always dependent, no matter how different they look.", "feedback_wrong_hy": "Տարբեր լինելը (A) կամ զույգ առ զույգ ոչ-բազմապատիկ լինելը (B) բավարար չէ՝ երեք վեկտոր կարող են զույգ առ զույգ ոչ զուգահեռ լինել, բայց դեռ կախված. Իրական պատճառը չափողականության սահմանն է (C).", "feedback_wrong_en": "Being distinct (A) or pairwise non-multiples (B) is not enough - three vectors can be pairwise non-parallel yet still dependent. The real reason is the dimension cap (C)."}, {"id": "LA-06", "area": "linear_algebra", "module": "02", "difficulty": "2", "template": "predict", "question_hy": "Ընդհանուր քառակուսի A և B մատրիցների համար արդյո՞ք AB-ն նույնն է, ինչ BA-ն:", "question_en": "For general square matrices A and B, is AB the same as BA?", "optA_hy": "այո, մատրիցների բազմապատկումը տեղափոխական է", "optA_en": "yes, matrix multiplication is commutative", "optB_hy": "ոչ՝ ընդհանուր դեպքում AB != BA, կարգը կարևոր է", "optB_en": "no - in general AB != BA; order matters", "optC_hy": "միայն եթե նրանք նույն չափի են", "optC_en": "only if they are the same size", "optD_hy": "այո, բայց տարբերվում են միայն իրենց որոշիչները", "optD_en": "yes, but only their determinants differ", "correct": "B", "points": "1", "feedback_correct_hy": "Մատրիցների բազմապատկումն ընդհանուր դեպքում տեղափոխական ՉԷ. AB-ն և BA-ն սովորաբար տարբերվում են (և կարող են նույնիսկ երկուսն էլ սահմանված չլինել): Կարգը կարևոր է՝ ի տարբերություն թվերի:", "feedback_correct_en": "Matrix multiplication is NOT commutative in general: AB and BA usually differ (and may not even both be defined). Order matters - a key difference from numbers.", "feedback_wrong_hy": "Տեղափոխական չէ (A): Նույն չափը չի դարձնում այն տեղափոխական (C): Արտադրյալները տարբերվում են որպես մատրիցներ, ոչ միայն որոշիչով (D):", "feedback_wrong_en": "It is not commutative (A). Same size does not make it commutative (C). The products differ as matrices, not just in determinant (D)."}, {"id": "LA-07", "area": "linear_algebra", "module": "03", "difficulty": "3", "template": "match", "question_hy": "Ի՞նչ է անում գլխավոր բաղադրիչների վերլուծությունը (PCA), ինտուիտիվ առումով:", "question_en": "What does Principal Component Analysis (PCA) do, intuitively?", "optA_hy": "պատահականորեն ջնջում է սյուներ՝ տվյալները փոքրացնելու համար", "optA_en": "it deletes random columns to shrink the data", "optB_hy": "գտնում է նոր օրթոգոնալ առանցքներ՝ դասավորված ըստ գրավված դիսպերսիայի, որ կարողանաս պահել վերին մի քանիսը", "optB_en": "it finds new orthogonal axes ordered by how much variance they capture, so you can keep the top few", "optC_hy": "միայն բոլոր հատկանիշների միջինը դարձնում է զրո", "optC_en": "it only makes all features have mean zero", "optD_hy": "դասավորում է տվյալների տողերը", "optD_en": "it sorts the rows of the dataset", "correct": "B", "points": "1", "feedback_correct_hy": "PCA-ն գտնում է օրթոգոնալ ուղղություններ (գլխավոր բաղադրիչներ՝ կովարիացիոն մատրիցի սեփական վեկտորների / SVD-ի միջոցով)՝ դասավորված ըստ գրավված դիսպերսիայի: Վերին բաղադրիչները պահելը նվազեցնում է չափողականությունը՝ նվազագույն ինֆորմացիայի կորստով:", "feedback_correct_en": "PCA finds orthogonal directions (principal components, via the eigenvectors of the covariance matrix / the SVD) ordered by captured variance. Keeping the top components reduces dimensionality with minimal information loss.", "feedback_wrong_hy": "Սա սկզբունքային է, ոչ պատահական ջնջում (A): Ավելին է անում, քան կենտրոնացումը (C): Չի վերադասավորում տողերը (D): Կառուցում է ըստ դիսպերսիայի դասավորված առանցքներ (B):", "feedback_wrong_en": "It is principled, not random deletion (A). It does more than center the data (C). It does not reorder rows (D). It builds variance-ranked axes (B)."}, {"id": "CALC-01", "area": "calculus", "module": "04", "difficulty": "2", "template": "misconception", "question_hy": "Ֆունկցիան անընդհատ է x0 կետում: Արդյո՞ք դա երաշխավորում է, որ այն ածանցելի է x0-ում:", "question_en": "A function is continuous at a point x0. Does that guarantee it is differentiable at x0?", "optA_hy": "Այո՝ անընդհատությունը միշտ ենթադրում է ածանցելիություն", "optA_en": "yes - continuity always implies differentiability", "optB_hy": "Ոչ՝ օրինակ |x|-ը անընդհատ է 0-ում, բայց ունի անկյուն, ուստի ածանցելի չէ", "optB_en": "no - e.g. |x| is continuous at 0 but has a corner, so not differentiable", "optC_hy": "Միայն եթե ֆունկցիան այդտեղ աճող է", "optC_en": "only if the function is increasing there", "optD_hy": "Ածանցելիությունն ու անընդհատությունը կապ չունեն", "optD_en": "differentiability and continuity are unrelated", "correct": "B", "points": "1", "feedback_correct_hy": "Ածանցելիությունը ենթադրում է անընդհատություն, բայց ոչ հակառակը: |x|-ը 0-ում դասական հակաօրինակն է՝ անկյունը չունի միակ շոշափողի թեքություն:", "feedback_correct_en": "Differentiable implies continuous, but not the reverse. |x| at 0 is the standard counterexample - a corner has no single tangent slope.", "feedback_wrong_hy": "Հետևությունը մի ուղղությամբ է՝ ածանցելի => անընդհատ, ոչ երբեք հակառակը (A): Մոնոտոնությունն անկապ է (C): Նրանք կապ ունեն՝ մի ուղղությունը ճիշտ է (D):", "feedback_wrong_en": "The implication goes one way: differentiable => continuous, never the reverse (A). Monotonicity is irrelevant (C). They are related - one direction holds (D)."}, {"id": "CALC-02", "area": "calculus", "module": "04", "difficulty": "2", "template": "predict", "question_hy": "Ֆունկցիան հորիզոնական ուղղությամբ սեղմում ես՝ f(x)-ը փոխարինելով f(2x)-ով: f-ի համեմատ նոր ֆունկցիան փոխվում է...", "question_en": "You compress a function horizontally by replacing f(x) with f(2x). Compared with f, the new function changes...", "optA_hy": "նույն տեմպով", "optA_en": "at the same rate", "optB_hy": "երկու անգամ ավելի արագ (շղթայի կանոնով ածանցյալը կրկնապատկվում է)", "optB_en": "twice as fast (its derivative is doubled by the chain rule)", "optC_hy": "կիսով չափ դանդաղ", "optC_en": "half as fast", "optD_hy": "հնարավոր չէ որոշել առանց f-ի", "optD_en": "cannot be determined without f", "correct": "B", "points": "1", "feedback_correct_hy": "Շղթայի կանոնով d/dx f(2x) = 2 f'(2x)՝ ներքին 2 գործակիցը մասշտաբավորում է տեմպը: Հորիզոնական սեղմումն արագացնում է փոփոխությունը:", "feedback_correct_en": "By the chain rule d/dx f(2x) = 2 f'(2x): the inner factor 2 scales the rate. Horizontal compression speeds up the change.", "feedback_wrong_hy": "Շղթայի կանոնը բազմապատկում է ներքին ածանցյալով (այստեղ՝ 2), ուստի տեմպը կրկնապատկվում է, ոչ նույնը (A), ոչ կիսով չափ (C): Որոշվում է շղթայի կանոնով՝ անկախ f-ից (D):", "feedback_wrong_en": "The chain rule multiplies by the inner derivative (here 2), so the rate doubles - not the same (A), not half (C). It is fully determined by the chain rule regardless of f (D)."}, {"id": "CALC-03", "area": "calculus", "module": "05", "difficulty": "2", "template": "predict", "question_hy": "Երկու անգամ ածանցելի ֆունկցիայի համար f''(x) > 0 բոլոր x-երի համար: Ի՞նչ կարող ես եզրակացնել:", "question_en": "A twice-differentiable function has f''(x) > 0 for all x. What can you conclude?", "optA_hy": "f-ը գոգավոր է (բացվում է ներքև)", "optA_en": "f is concave (opens downward)", "optB_hy": "f-ը ուռուցիկ է (բացվում է վերև), ցանկացած լոկալ մինիմում գլոբալ է", "optB_en": "f is convex (opens upward); any local min is the global min", "optC_hy": "f-ը ամենուր աճող է", "optC_en": "f is increasing everywhere", "optD_hy": "f-ը կրիտիկական կետեր չունի", "optD_en": "f has no critical points", "correct": "B", "points": "1", "feedback_correct_hy": "f'' > 0 նշանակում է ուռուցիկ: Կարևոր հետևանք՝ ուռուցիկ ֆունկցիան վատ լոկալ մինիմումներ չունի՝ ցանկացած լոկալ մինիմում գլոբալ է:", "feedback_correct_en": "f'' > 0 means convex. A key consequence: a convex function has no bad local minima - any local min is global.", "feedback_wrong_hy": "f'' > 0-ն ուռուցիկ է (բացվում է վերև), ոչ գոգավոր (A): Ոչինչ չի ասում աճելու մասին (C)՝ դա f'-ն է, ոչ f''-ը: Ուռուցիկ ֆունկցիան կարող է ունենալ կրիտիկական կետ՝ գլոբալ մինիմումը (D):", "feedback_wrong_en": "f'' > 0 is convex (opens upward), not concave (A). It says nothing about whether f increases (C) - that is f', not f''. A convex function can still have a critical point, the global min (D)."}, {"id": "CALC-04", "area": "calculus", "module": "05", "difficulty": "2", "template": "match", "question_hy": "f ֆունկցիայի Թեյլորի բազմանդամը a կետի շուրջ լավագույնս նկարագրվում է որպես...", "question_en": "The Taylor polynomial of f around a point a is best described as...", "optA_hy": "f-ի ճշգրիտ բանաձև՝ վավեր ամենուր", "optA_en": "an exact formula for f valid everywhere", "optB_hy": "լոկալ բազմանդամային մոտարկում, որն ամենաճշգրիտն է a-ի մոտ", "optB_en": "a local polynomial approximation that is most accurate near a", "optC_hy": "գործիք, որ աշխատում է միայն եռանկյունաչափական ֆունկցիաների համար", "optC_en": "a tool that only works for trigonometric functions", "optD_hy": "f-ի թեքությունը a-ում", "optD_en": "the slope of f at a", "correct": "B", "points": "1", "feedback_correct_hy": "Թեյլորը f-ը լոկալ մոտարկում է բազմանդամով. ճշգրտությունն ամենաբարձրն է a-ի մոտ և սովորաբար նվազում է հեռանալիս: Անդամներ ավելացնելը բարելավում է լոկալ ճշգրտությունը:", "feedback_correct_en": "Taylor approximates f locally by a polynomial; accuracy is highest near a and usually degrades as you move away. Adding terms improves the local fit.", "feedback_wrong_hy": "Թեյլորը ընդհանուր դեպքում մոտարկում է, ճշգրիտ՝ միայն բազմանդամների համար, ոչ ամենուր (A): Կիրառվում է ցանկացած ողորկ ֆունկցիայի, ոչ միայն եռանկյունաչափականի (C): Թեքությունը պարզապես առաջին կարգի անդամն է (D):", "feedback_wrong_en": "Taylor is generally an approximation, exact only for polynomials, not everywhere (A). It applies to any smooth function, not just trig (C). The slope is just the first-order term (D)."}, {"id": "CALC-05", "area": "calculus", "module": "07", "difficulty": "2", "template": "misconception", "question_hy": "Տրված կետում բազմափոփոխական f ֆունկցիայի գրադիենտն ուղղված է...", "question_en": "At a point, the gradient of a multivariate function f points...", "optA_hy": "դեպի մոտակա մինիմումը", "optA_en": "toward the nearest minimum", "optB_hy": "f-ի ամենաարագ աճի ուղղությամբ", "optB_en": "in the direction of steepest increase of f", "optC_hy": "մակարդակի գծի երկայնքով (որտեղ f-ը հաստատուն է)", "optC_en": "along the level curve (where f is constant)", "optD_hy": "միշտ հորիզոնական", "optD_en": "always horizontally", "correct": "B", "points": "1", "feedback_correct_hy": "Գրադիենտն ուղղված է ամենաարագ աճի ուղղությամբ և ուղղահայաց է մակարդակի գծին: Գրադիենտային վայրէջքը շարժվում է հակառակ (բացասական գրադիենտի) ուղղությամբ:", "feedback_correct_en": "The gradient points in the direction of steepest ascent and is perpendicular to the level curve. Gradient descent moves in the opposite (negative gradient) direction.", "feedback_wrong_hy": "Ուղղված է ամենաարագ աճին, ոչ դեպի մինիմումը (A)՝ դա բացասական գրադիենտի գործն է: Ուղղահայաց է մակարդակի գծին, ոչ նրա երկայնքով (C): Ուղղությունը կախված է f-ից, ֆիքսված չէ (D):", "feedback_wrong_en": "It points to steepest ascent, not toward a minimum (A) - that is the negative gradient. It is perpendicular to, not along, the level curve (C). Direction depends on f, not fixed (D)."}, {"id": "CALC-06", "area": "calculus", "module": "07", "difficulty": "3", "template": "misconception", "question_hy": "Կրիտիկական կետում (գրադիենտ = 0) հեսիան մատրիցն ունի և՛ դրական, և՛ բացասական սեփական արժեքներ: Կետը...", "question_en": "At a critical point (gradient = 0), the Hessian has both positive and negative eigenvalues. The point is...", "optA_hy": "լոկալ մինիմում", "optA_en": "a local minimum", "optB_hy": "լոկալ մաքսիմում", "optB_en": "a local maximum", "optC_hy": "թամբի կետ", "optC_en": "a saddle point", "optD_hy": "անհնար՝ սեփական արժեքները պետք է նույն նշանն ունենան", "optD_en": "impossible - the eigenvalues must share a sign", "correct": "C", "points": "1", "feedback_correct_hy": "Հեսիանի տարբեր նշանի սեփական արժեքները նշանակում են, որ մակերևույթը մի ուղղություններով բարձրանում է, մյուսներով՝ իջնում՝ թամբի կետ, ոչ մինիմում, ոչ մաքսիմում:", "feedback_correct_en": "Mixed-sign eigenvalues of the Hessian mean the surface curves up in some directions and down in others - a saddle point, neither a min nor a max.", "feedback_wrong_hy": "Մինիմումի համար բոլոր սեփական արժեքները դրական պետք է լինեն (A), մաքսիմումի՝ բոլորը բացասական (B): Տարբեր նշանները միանգամայն հնարավոր են և սահմանում են թամբի կետ (C, D):", "feedback_wrong_en": "A minimum needs all eigenvalues positive (A), a maximum all negative (B). Mixed signs are perfectly possible and define a saddle (C, D)."}, {"id": "CALC-07", "area": "calculus", "module": "06", "difficulty": "2", "template": "misconception", "question_hy": "Ի՞նչ է ներկայացնում f-ի որոշյալ ինտեգրալը a-ից b:", "question_en": "What does the definite integral of f from a to b represent?", "optA_hy": "f-ի թեքությունը b կետում", "optA_en": "the slope of f at b", "optB_hy": "նշանով մակերեսը f կորի և x առանցքի միջև a-ից b", "optB_en": "the signed area between the curve f and the x-axis from a to b", "optC_hy": "f-ի մաքսիմումը [a, b]-ի վրա", "optC_en": "the maximum of f on [a, b]", "optD_hy": "f(a)-ի և f(b)-ի միջինը", "optD_en": "the average of f(a) and f(b)", "correct": "B", "points": "1", "feedback_correct_hy": "Որոշյալ ինտեգրալը կուտակում է նշանով մակերեսը f-ի և x առանցքի միջև (առանցքից ներքև մակերեսը հաշվվում է բացասական): Նյուտոն-Լայբնիցի բանաձևը կապում է այն նախնականի հետ՝ ինտեգրալ = F(b) - F(a):", "feedback_correct_en": "The definite integral accumulates signed area between f and the x-axis (area below the axis counts as negative). The Fundamental Theorem links it to antiderivatives: integral = F(b) - F(a).", "feedback_wrong_hy": "Թեքությունը ածանցյալն է, ոչ ինտեգրալը (A): Մաքսիմումը (C) կամ ծայրակետերի միջինը (D) չէ: Դա կուտակված նշանով մակերեսն է (B):", "feedback_wrong_en": "Slope is the derivative, not the integral (A). It is not the max (C) or a simple endpoint average (D). It is accumulated signed area (B)."}, {"id": "OPT-01", "area": "optimization", "module": "09", "difficulty": "2", "template": "predict", "question_hy": "Գրադիենտային վայրէջք ես անում ողորկ ուռուցիկ ամանի վրա: Ուսուցման տեմպը (քայլի չափը) դարձնում ես շատ մեծ: Ամենահավանական արդյունքը...", "question_en": "You run gradient descent on a smooth convex bowl. You make the learning rate (step size) very large. The most likely result is...", "optA_hy": "ավելի արագ երաշխավորված զուգամիտություն դեպի մինիմումը", "optA_en": "faster guaranteed convergence to the minimum", "optB_hy": "քայլերը գերանցում են և կարող են տատանվել կամ տարամիտել", "optB_en": "the iterates overshoot and may oscillate or diverge", "optC_hy": "զուգամիտում է այլ, սխալ մինիմումի", "optC_en": "it converges to a different, wrong minimum", "optD_hy": "ոչինչ չի փոխվում՝ քայլի չափը նշանակություն չունի", "optD_en": "nothing changes - step size does not matter", "correct": "B", "points": "1", "feedback_correct_hy": "Չափազանց մեծ քայլը ամեն թարմացման ժամանակ գերանցում է մինիմումը. քայլերը կարող են ցատկոտել կամ պայթել: Քայլի չափը պետք է բավական փոքր լինի կորության համեմատ:", "feedback_correct_en": "Too large a step overshoots the minimum each update; the iterates can bounce around or blow up. Step size must be small enough relative to the curvature.", "feedback_wrong_hy": "Մեծը անվտանգ կերպով արագ չէ (A)՝ շեմն անցնելուց հետո տարամիտում է: Ուռուցիկ ամանն ունի մեկ մինիմում, ուստի այլ չի գտնի (C): Քայլի չափը կրիտիկական է (D):", "feedback_wrong_en": "Bigger is not safely faster (A) - past a threshold it diverges. A convex bowl has one minimum, so it cannot find a different one (C). Step size is critical (D)."}, {"id": "OPT-02", "area": "optimization", "module": "09", "difficulty": "2", "template": "misconception", "question_hy": "Գրադիենտային վայրէջքը զուգամիտել է կետի, որտեղ գրադիենտը զրո է: Կարո՞ղ ես եզրակացնել, որ գտել ես գլոբալ մինիմումը:", "question_en": "Gradient descent converged to a point where the gradient is zero. Can you conclude you found the global minimum?", "optA_hy": "Այո, զրո գրադիենտը միշտ նշանակում է գլոբալ մինիմում", "optA_en": "yes, zero gradient always means a global minimum", "optB_hy": "Միայն եթե ֆունկցիան ուռուցիկ է, այլապես կարող է լինել լոկալ մինիմում կամ թամբի կետ", "optB_en": "only if the function is convex; otherwise it could be a local min or a saddle", "optC_hy": "Այո, քանի որ ԳՎ-ն կանգ է առնում միայն գլոբալ մինիմումներում", "optC_en": "yes, because GD only stops at global minima", "optD_hy": "Ոչ, ԳՎ-ն երբեք չի հասնում մինիմումի", "optD_en": "no, GD never reaches any minimum", "correct": "B", "points": "1", "feedback_correct_hy": "Զրո գրադիենտը նշանակում է միայն ստացիոնար կետ: Ուռուցիկ ֆունկցիաների համար այդպիսի ցանկացած կետ գլոբալ մինիմում է, ոչ ուռուցիկների համար կարող է լինել լոկալ մինիմում, մաքսիմում կամ թամբ:", "feedback_correct_en": "Zero gradient only means a stationary point. For convex functions any such point is the global min; for non-convex ones it can be a local min, max, or saddle.", "feedback_wrong_hy": "Զրո գրադիենտն անհրաժեշտ է, բայց ոչ բավարար գլոբալ մինիմումի համար (A, C)՝ այն ճիշտ է նաև թամբերում ու լոկալ էքստրեմումներում: ԳՎ-ն իրոք հասնում է ստացիոնար կետերի (D):", "feedback_wrong_en": "Zero gradient is necessary, not sufficient, for a global min (A, C) - it holds at saddles and local extrema too. GD does converge to stationary points (D)."}, {"id": "OPT-03", "area": "optimization", "module": "10", "difficulty": "2", "template": "misconception", "question_hy": "Գրադիենտային վայրէջքին իներցիա (momentum) ավելացնելը հիմնականում ի՞նչ է անում:", "question_en": "What does adding momentum to gradient descent primarily do?", "optA_hy": "Երաշխավորում է գլոբալ մինիմումի գտնելը", "optA_en": "it guarantees finding the global minimum", "optB_hy": "Կուտակում է անցյալ գրադիենտները՝ հարթեցնելով ուղին և արագացնելով հետևողական ուղղություններում", "optB_en": "it accumulates past gradients to smooth the path and speed up in consistent directions", "optC_hy": "Վերացնում է ուսուցման տեմպի կարիքը", "optC_en": "it removes the need for a learning rate", "optD_hy": "Ամեն քայլը դարձնում է գրադիենտին ուղղահայաց", "optD_en": "it makes every step perpendicular to the gradient", "correct": "B", "points": "1", "feedback_correct_hy": "Իներցիան պահում է անցյալ գրադիենտների շարժվող միջինը՝ մարելով տատանումները և արագացնելով հետևողական ուղղություններով: Չի փոխում, թե որն է օպտիմումը:", "feedback_correct_en": "Momentum keeps a running average of past gradients, damping oscillations across ravines and accelerating along consistent directions. It does not change what the optimum is.", "feedback_wrong_hy": "Իներցիան չի երաշխավորում գլոբալ օպտիմումը (A): Ուսուցման տեմպը դեռ պետք է (C): Քայլերը հետևում են կուտակված գրադիենտին, ոչ ուղղահայացին (D):", "feedback_wrong_en": "Momentum does not guarantee the global optimum (A). You still need a learning rate (C). Steps follow the accumulated gradient, not a perpendicular (D)."}, {"id": "OPT-04", "area": "optimization", "module": "11", "difficulty": "3", "template": "compare", "question_hy": "Ինչո՞վ է Նյուտոնի մեթոդը տարբերվում սովորական գրադիենտային վայրէջքից:", "question_en": "How does Newton's method differ from plain gradient descent?", "optA_hy": "Նյուտոնի մեթոդն ընդհանրապես անտեսում է գրադիենտը", "optA_en": "Newton ignores the gradient entirely", "optB_hy": "Նյուտոնը օգտագործում է երկրորդ կարգի կորություն (հեսիան), ուստի մինիմումի մոտ կարող է ավելի արագ զուգամիտել, բայց ամեն քայլն ավելի թանկ է", "optB_en": "Newton uses second-order curvature (the Hessian), so it can converge faster near a minimum but costs more per step", "optC_hy": "Նյուտոնը միշտ զուգամիտում է ցանկացած մեկնարկից", "optC_en": "Newton always converges from any starting point", "optD_hy": "Նրանք նույնն են, պարզապես տարբեր անուններ", "optD_en": "they are identical, just different names", "correct": "B", "points": "1", "feedback_correct_hy": "Նյուտոնը քայլը մասշտաբավորում է հակադարձ հեսիանով՝ կորությունն օգտագործելով արագ (քառակուսային) լոկալ զուգամիտության համար, բայց ամեն քայլ պահանջում է հեսիան և համակարգի լուծում՝ ավելի թանկ և գլոբալ չերաշխավորված:", "feedback_correct_en": "Newton scales the step by the inverse Hessian, using curvature for fast (quadratic) local convergence, but each step needs the Hessian and a solve - more expensive and not globally guaranteed.", "feedback_wrong_hy": "Նյուտոնն օգտագործում է և՛ գրադիենտը, և՛ հեսիանը (A): Զուգամիտում է միայն լոկալ, ոչ ամեն տեղից (C): Իրապես տարբերվում է առաջին կարգի ԳՎ-ից (D):", "feedback_wrong_en": "Newton uses both the gradient and the Hessian (A). It is only locally convergent, not from anywhere (C). It is genuinely different from first-order GD (D)."}, {"id": "OPT-05", "area": "optimization", "module": "12", "difficulty": "2", "template": "match", "question_hy": "Ո՞ր իրավիճակում է ածանցյալից անկախ մեթոդը (օրինակ՝ Nelder-Mead) բնական ընտրությունը:", "question_en": "In which situation is a derivative-free method (like Nelder-Mead) the natural choice?", "optA_hy": "երբ նպատակային ֆունկցիան ողորկ է և գրադիենտները էժան են", "optA_en": "when the objective is smooth and gradients are cheap", "optB_hy": "երբ նպատակային ֆունկցիան աղմկոտ է կամ ոչ ածանցելի, և գրադիենտներ հասանելի չեն", "optB_en": "when the objective is noisy or non-differentiable and gradients are unavailable", "optC_hy": "միայն երբ խնդիրը միաչափ է", "optC_en": "only when the problem is one-dimensional", "optD_hy": "երբ ուզում ես երաշխավորված գլոբալ օպտիմալություն", "optD_en": "whenever you want guaranteed global optimality", "correct": "B", "points": "1", "feedback_correct_hy": "Ածանցյալից անկախ մեթոդները փայլում են հենց այնտեղ, որտեղ գրադիենտ հաշվել հնարավոր չէ՝ սև արկղ, աղմկոտ կամ ոչ ողորկ ֆունկցիաներ: Գրադիենտի փոխարեն վճարում են ֆունկցիայի ավելի շատ հաշվարկներով:", "feedback_correct_en": "Derivative-free methods shine exactly when you cannot compute gradients - black-box, noisy, or non-smooth objectives. They trade gradient information for more function evaluations.", "feedback_wrong_hy": "Եթե գրադիենտները էժան են և ֆունկցիան ողորկ, գրադիենտային մեթոդներն ավելի լավն են (A): Ածանցյալից անկախ մեթոդներն աշխատում են շատ չափերում (C) և գլոբալ երաշխիք չեն տալիս (D):", "feedback_wrong_en": "If gradients are cheap and the function is smooth, gradient methods are better (A). Derivative-free methods work in many dimensions (C) and give no global guarantee (D)."}, {"id": "OPT-06", "area": "optimization", "module": "09", "difficulty": "3", "template": "misconception", "question_hy": "Քառակուսային աման շատ ձգված է (վատ պայմանավորված՝ մեծ condition number): Գրադիենտային վայրէջքի համար սա նշանակում է...", "question_en": "A quadratic bowl is very elongated (ill-conditioned: large condition number). For gradient descent this means...", "optA_hy": "զուգամիտությունը կախված չէ ձևից", "optA_en": "convergence is unaffected by the shape", "optB_hy": "գրադիենտային վայրէջքը զիգզագ է անում և դանդաղ զուգամիտում", "optB_en": "gradient descent zig-zags and converges slowly", "optC_hy": "մինիմում գոյություն չունի", "optC_en": "there is no minimum to find", "optD_hy": "գրադիենտը զրո է ամենուր", "optD_en": "the gradient is zero everywhere", "correct": "B", "points": "1", "feedback_correct_hy": "Մեծ condition number-ը նշանակում է մի ուղղությամբ զառիթափ, մյուսով՝ տափակ: ԳՎ-ն ցատկում է զառիթափ պատերի միջև՝ դանդաղ սողալով տափակ հովտով: Ահա թե ինչու են պայմանավորվածությունը (և իներցիան/preconditioning-ը) կարևոր:", "feedback_correct_en": "A large condition number means steep in one direction, shallow in another. GD bounces across the steep walls while crawling along the shallow valley - slow zig-zag. This is why conditioning (and momentum/preconditioning) matters.", "feedback_wrong_hy": "Ձևը շատ կարևոր է (A): Մինիմումը դեռ գոյություն ունի (C): Գրադիենտը զրո է միայն մինիմումում, ոչ ամենուր (D):", "feedback_wrong_en": "Shape matters a lot (A). The minimum still exists (C). The gradient is only zero at the minimum, not everywhere (D)."}, {"id": "OPT-07", "area": "optimization", "module": "14", "difficulty": "2", "template": "match", "question_hy": "Բայեսյան օպտիմիզացիան հատկապես օգտակար է ո՞ր տեսակի խնդրի համար:", "question_en": "Bayesian optimization is especially useful for which kind of problem?", "optA_hy": "հայտնի գրադիենտներով էժան ֆունկցիայի մինիմիզացում", "optA_en": "minimizing a cheap function with known gradients", "optB_hy": "թանկ սև-արկղ ֆունկցիայի (օրինակ՝ ML հիպերպարամետրերի) կարգաբերում՝ հնարավորինս քիչ հաշվարկներով", "optB_en": "tuning an expensive black-box function (e.g. ML hyperparameters) in as few evaluations as possible", "optC_hy": "գծային համակարգերի ճշգրիտ լուծում", "optC_en": "solving linear systems exactly", "optD_hy": "մեծ ցուցակի դասավորում", "optD_en": "sorting a large list", "correct": "B", "points": "1", "feedback_correct_hy": "Բայեսյան օպտիմիզացիան կառուցում է թանկ նպատակային ֆունկցիայի էժան փոխարինող մոդել և օգտագործում acquisition ֆունկցիա՝ ընտրելու ամենահեռանկարային հաջորդ կետը՝ իդեալական, երբ ամեն հաշվարկ թանկ է (մոդելի ուսուցում):", "feedback_correct_en": "Bayesian optimization builds a cheap surrogate model of an expensive objective and uses an acquisition function to pick the most promising next point - ideal when each evaluation is costly (training a model).", "feedback_wrong_hy": "Եթե ֆունկցիան էժան է գրադիենտներով, գրադիենտային մեթոդները հաղթում են (A): Գծային ճշգրիտ լուծման (C) կամ դասավորման (D) համար չէ: Փայլում է թանկ սև արկղերի վրա (B):", "feedback_wrong_en": "If the function is cheap with gradients, gradient methods win (A). It is not for exact linear solves (C) or sorting (D). It shines on expensive black boxes (B)."}, {"id": "OPT-08", "area": "optimization", "module": "15", "difficulty": "2", "template": "misconception", "question_hy": "Բազմաչափանիշ օպտիմիզացիայում (օրինակ՝ առավելագույնի հասցնել ճշգրտությունը ԵՎ նվազագույնի՝ ուշացումը), ի՞նչ է Պարետո-օպտիմալ լուծումը:", "question_en": "In multi-objective optimization (e.g. maximize accuracy AND minimize latency), what is a Pareto-optimal solution?", "optA_hy": "միակ լավագույն ընդհանուր լուծումը", "optA_en": "the single best solution overall", "optB_hy": "այն, որտեղ չես կարող բարելավել որևէ չափանիշ՝ առանց մյուսը վատացնելու", "optB_en": "one where you cannot improve any objective without worsening another", "optC_hy": "բոլոր չափանիշների միջինը", "optC_en": "the average of all the objectives", "optD_hy": "ցանկացած թույլատրելի լուծում", "optD_en": "any feasible solution", "correct": "B", "points": "1", "feedback_correct_hy": "Մրցակցող չափանիշների դեպքում սովորաբար չկա միակ լավագույն կետ. Պարետո-օպտիմալ (չգերակայված) լուծումն այն է, որտեղ մեկ չափանիշի բարելավումն անպայման վատացնում է մյուսը: Դրանց բազմությունը կազմում է Պարետոյի ճակատը:", "feedback_correct_en": "With competing objectives there is usually no single best point; a Pareto-optimal (non-dominated) solution is one where improving one objective necessarily worsens another. The set of these forms the Pareto front.", "feedback_wrong_hy": "Փոխզիջումների դեպքում հազվադեպ կա մեկ ընդհանուր լավագույն (A): Միջին (C) կամ պարզապես ցանկացած թույլատրելի կետ (D) չէ: Այն չգերակայված է (B):", "feedback_wrong_en": "With trade-offs there is rarely one overall best (A). It is not an average (C) or just any feasible point (D). It is non-dominated (B)."}, {"id": "PROB-01", "area": "probability", "module": "16", "difficulty": "3", "template": "misconception", "question_hy": "Հազվադեպ հիվանդության թեստը 99% ճշգրիտ է: Մարդը դրական արդյունք է ստանում: Ինչո՞ւ կարող է նրա իրականում հիվանդ լինելու հավանականությունը դեռ ցածր լինել:", "question_en": "A test for a rare disease is 99% accurate. Someone tests positive. Why might the probability they actually have the disease still be low?", "optA_hy": "Թեստի արդյունքը պետք է սխալ լինի", "optA_en": "the test result must be wrong", "optB_hy": "Քանի որ հիվանդությունը հազվադեպ է, դրական արդյունքների մեծ մասը կարող է կեղծ դրական լինել (բազային հաճախության էֆեկտ՝ Բայեսով)", "optB_en": "because the disease is rare, most positives can be false positives (base-rate effect via Bayes)", "optC_hy": "99% ճշգրտությունը նշանակում է 99% հավանականություն՝ հիվանդ լինելու", "optC_en": "99% accuracy means a 99% chance of having the disease", "optD_hy": "Ճշգրտությունն ու հիվանդ լինելու հավանականությունը նույն բանն են", "optD_en": "accuracy and the chance of disease are the same thing", "correct": "B", "points": "1", "feedback_correct_hy": "P(հիվանդ | դրական)-ը նույնը չէ, ինչ P(դրական | հիվանդ): Երբ բազային հաճախությունը շատ փոքր է, նույնիսկ փոքր կեղծ-դրական տոկոսը տալիս է շատ ավելի շատ կեղծ դրականներ, քան իսկական: Սա Բայեսի թեորեմն է:", "feedback_correct_en": "P(disease | positive) is not P(positive | disease). When the base rate is tiny, even a small false-positive rate produces many more false positives than true positives. This is Bayes' theorem at work.", "feedback_wrong_hy": "Արդյունքը պարտադիր սխալ չէ (A): 99% ճշգրտությունը P(ճիշտ | վիճակ)-ն է, ոչ P(հիվանդ | դրական) (C, D)՝ դրանք շփոթելը բազային հաճախության սխալն է:", "feedback_wrong_en": "The result need not be wrong (A). 99% accuracy is P(correct | status), not P(disease | positive) (C, D) - confusing the two is the base-rate fallacy."}, {"id": "PROB-02", "area": "probability", "module": "16", "difficulty": "2", "template": "flaw", "question_hy": "Փաստարկ. «A և B պատահույթները չեն կարող միաժամանակ տեղի ունենալ (անհամատեղելի են), ուստի անկախ են»: Որտե՞ղ է սխալը:", "question_en": "Argument: 'Events A and B cannot happen together (mutually exclusive), so they are independent.' Where is the flaw?", "optA_hy": "Փաստարկը ճիշտ է՝ անհամատեղելին նշանակում է անկախ", "optA_en": "the argument is correct - exclusive means independent", "optB_hy": "Ոչ զրոյական հավանականությամբ անհամատեղելի պատահույթներն իրականում կախված են. A-ի տեղի ունենալն ասում է, որ B-ն տեղի չի ունեցել", "optB_en": "mutually exclusive events with nonzero probability are actually dependent: knowing A happened tells you B did not", "optC_hy": "Անկախությունը հնարավոր չէ սահմանել երկու պատահույթի համար", "optC_en": "independence is impossible to define for two events", "optD_hy": "Անհամատեղելի պատահույթները միշտ զրո հավանականություն ունեն", "optD_en": "mutually exclusive events always have probability zero", "correct": "B", "points": "1", "feedback_correct_hy": "Անհամատեղելի նշանակում է P(A և B) = 0: Անկախ նշանակում է P(A և B) = P(A)P(B): Ոչ զրոյական P(A), P(B)-ի դեպքում սրանք հակասում են՝ ուստի անհամատեղելի պատահույթները կախված են, պնդման հակառակը:", "feedback_correct_en": "Mutually exclusive means P(A and B) = 0. Independence means P(A and B) = P(A)P(B). For nonzero P(A), P(B) these clash - so exclusive events are dependent, the opposite of the claim.", "feedback_wrong_hy": "Անհամատեղելիությունը անկախություն չի տալիս (A)՝ այն պարտադրում է կախվածություն: Անկախությունը լավ սահմանված է (C): Անհամատեղելի պատահույթները կարող են առանձին դրական հավանականություններ ունենալ (D):", "feedback_wrong_en": "Exclusivity does not give independence (A) - it forces dependence. Independence is well-defined (C). Exclusive events can have positive individual probabilities (D)."}, {"id": "PROB-03", "area": "probability", "module": "17", "difficulty": "2", "template": "misconception", "question_hy": "Մաթսպասման մասին ո՞ր պնդումն է միշտ ճիշտ, նույնիսկ երբ X-ը և Y-ը կախված են:", "question_en": "Which statement about expectation is always true, even when X and Y are dependent?", "optA_hy": "E[XY] = E[X] E[Y]", "optA_en": "E[XY] = E[X] E[Y]", "optB_hy": "E[X + Y] = E[X] + E[Y]", "optB_en": "E[X + Y] = E[X] + E[Y]", "optC_hy": "Var(X + Y) = Var(X) + Var(Y)", "optC_en": "Var(X + Y) = Var(X) + Var(Y)", "optD_hy": "E[X^2] = (E[X])^2", "optD_en": "E[X^2] = (E[X])^2", "correct": "B", "points": "1", "feedback_correct_hy": "Մաթսպասման գծայնությունը E[X+Y]=E[X]+E[Y] միշտ ճիշտ է, անկախություն պետք չէ: Մյուսները պահանջում են անկախություն (A, C) կամ ընդհանուր դեպքում սխալ են (D):", "feedback_correct_en": "Linearity of expectation E[X+Y]=E[X]+E[Y] holds always, no independence needed. The others require independence (A, C) or are false in general (D).", "feedback_wrong_hy": "E[XY]=E[X]E[Y] (A) և գումարի դիսպերսիայի ադիտիվությունը (C) պահանջում են անկախություն (կամ զրո կովարիացիա): E[X^2]=(E[X])^2 միայն եթե դիսպերսիան 0 է (D): Միայն մաթսպասման ադիտիվությունն է անպայմանական (B):", "feedback_wrong_en": "E[XY]=E[X]E[Y] (A) and additive variance (C) need independence (or zero covariance). E[X^2]=(E[X])^2 only if Var=0 (D). Only additivity of expectation is unconditional (B)."}, {"id": "PROB-04", "area": "probability", "module": "18", "difficulty": "3", "template": "compare", "question_hy": "X-ի և Y-ի կորելացիան 0 է: Արդյո՞ք դա նշանակում է, որ նրանք անկախ են:", "question_en": "X and Y have correlation 0. Does that mean they are independent?", "optA_hy": "Այո, զրո կորելացիան նույնն է, ինչ անկախությունը", "optA_en": "yes, zero correlation is the same as independence", "optB_hy": "Ոչ՝ անկախությունը ենթադրում է զրո կորելացիա, բայց ոչ հակառակը (օրինակ՝ Y = X^2 սիմետրիկ X-ով)", "optB_en": "no - independence implies zero correlation, but not the reverse (e.g. Y = X^2 with symmetric X)", "optC_hy": "Այո, բայց միայն նորմալ բաշխումների համար", "optC_en": "yes, but only for normal distributions", "optD_hy": "Ոչ, զրո կորելացիան անհնար է իրական տվյալների համար", "optD_en": "no, zero correlation is impossible for real data", "correct": "B", "points": "1", "feedback_correct_hy": "Կորելացիան չափում է միայն գծային կապը: Անկախությունը պարտադրում է զրո կորելացիա, բայց ուժեղ ոչ գծային կապը (օրինակ՝ Y=X^2) կարող է զրո կորելացիա ունենալ՝ լինելով լիովին կախված:", "feedback_correct_en": "Correlation measures only linear association. Independence forces zero correlation, but a strong nonlinear relation (like Y=X^2) can have zero correlation while being fully dependent.", "feedback_wrong_hy": "Զրո կորելացիան անկախություն չէ (A)՝ բաց է թողնում ոչ գծային կախվածությունը: Բացը ընդհանուր է, ոչ միայն նորմալ դեպքում, թեև համատեղ նորմալ մեծությունների համար դրանք համընկնում են (C): Զրո կորելացիան տարածված է (D):", "feedback_wrong_en": "Zero correlation is not independence (A) - it misses nonlinear dependence. The gap is general, not normal-only, though for jointly normal variables they coincide (C). Zero correlation is common (D)."}, {"id": "PROB-05", "area": "probability", "module": "19", "difficulty": "2", "template": "match", "question_hy": "Հաշվում ես ժամում ստացված նամակների քանակը՝ համեմատաբար հազվադեպ պատահույթ, որ տեղի է ունենում կայուն միջին տեմպով: Ո՞ր բաշխումն է բնական մոդելը:", "question_en": "You count the number of emails arriving per hour, a rare-ish event happening at a steady average rate. Which distribution is the natural model?", "optA_hy": "Նորմալ", "optA_en": "Normal", "optB_hy": "Պուասոնի", "optB_en": "Poisson", "optC_hy": "Հավասարաչափ", "optC_en": "Uniform", "optD_hy": "Բեռնուլիի", "optD_en": "Bernoulli", "correct": "B", "points": "1", "feedback_correct_hy": "Հաստատուն միջին տեմպով անկախ պատահույթների քանակը միջակայքում ենթարկվում է Պուասոնի բաշխմանը: Նրա lambda պարամետրը միջին քանակն է:", "feedback_correct_en": "Counts of independent events at a constant average rate over an interval follow a Poisson distribution. Its parameter lambda is the mean count.", "feedback_wrong_hy": "Նորմալը անընդհատ է, ոչ քանակների համար (A): Հավասարաչափը ենթադրում է բոլոր արժեքների հավասար հավանականություն (C): Բեռնուլին մեկ այո/ոչ փորձ է (D): Քանակ միջակայքում => Պուասոն:", "feedback_wrong_en": "Normal is continuous, not for counts (A). Uniform assumes all values equally likely (C). Bernoulli is a single yes/no trial (D). Counts per interval => Poisson."}, {"id": "PROB-06", "area": "probability", "module": "20", "difficulty": "2", "template": "misconception", "question_hy": "Ի՞նչ է իրականում ասում Կենտրոնական սահմանային թեորեմը:", "question_en": "What does the Central Limit Theorem actually say?", "optA_hy": "Ցանկացած բավական մեծ տվյալների հավաքածու դառնում է նորմալ բաշխված", "optA_en": "any large enough dataset becomes normally distributed", "optB_hy": "Նմուշային միջինի բաշխումը մոտենում է նորմալին n-ի աճով, նույնիսկ եթե տվյալները նորմալ չեն", "optB_en": "the distribution of the sample mean approaches normal as n grows, even if the data is not normal", "optC_hy": "Տվյալների արժեքներն իրենք զուգամիտում են իրենց միջինին", "optC_en": "the data values themselves converge to their mean", "optD_hy": "Մեծ նմուշները դարձնում են պոպուլյացիան նորմալ", "optD_en": "larger samples make the population normal", "correct": "B", "points": "1", "feedback_correct_hy": "ԿՍԹ-ն վերաբերում է միջինի (կամ գումարի) բաշխմանը, ոչ հում տվյալներին: n-ի աճով այդ բաշխումը դառնում է մոտավորապես նորմալ՝ անկախ պոպուլյացիայի ձևից:", "feedback_correct_en": "The CLT is about the sampling distribution of the mean (or sum), not the raw data. As n grows, that distribution becomes approximately normal regardless of the population's shape.", "feedback_wrong_hy": "Հում տվյալները նորմալ չեն դառնում (A, D)՝ ասիմետրիկ տվյալները մնում են ասիմետրիկ: Արժեքները չեն փլվում միջինին (C): Հենց միջինի բաշխումն է դառնում նորմալ (B):", "feedback_wrong_en": "The raw data does not become normal (A, D) - skewed data stays skewed. Values do not collapse to the mean (C). It is the mean's distribution that goes normal (B)."}, {"id": "PROB-07", "area": "probability", "module": "17", "difficulty": "2", "template": "compare", "question_hy": "Երկու պատահական մեծության համար ե՞րբ է Var(X + Y) = Var(X) + Var(Y):", "question_en": "For two random variables, when is Var(X + Y) = Var(X) + Var(Y)?", "optA_hy": "միշտ", "optA_en": "always", "optB_hy": "միայն երբ X-ը և Y-ը կորելացված չեն (օրինակ՝ անկախ)", "optB_en": "only when X and Y are uncorrelated (e.g. independent)", "optC_hy": "երբեք", "optC_en": "never", "optD_hy": "միայն երբ X = Y", "optD_en": "only when X = Y", "correct": "B", "points": "1", "feedback_correct_hy": "Var(X+Y) = Var(X) + Var(Y) + 2 Cov(X,Y): Խաչաձև անդամն անհետանում է միայն երբ կովարիացիան զրո է (կորելացված չեն), ինչը անկախությունը երաշխավորում է:", "feedback_correct_en": "Var(X+Y) = Var(X) + Var(Y) + 2 Cov(X,Y). The cross term vanishes only when covariance is zero (uncorrelated), which independence guarantees.", "feedback_wrong_hy": "Միշտ ճիշտ չէ (A)՝ կովարիացիայի անդամը կարևոր է: Հաճախ ճիշտ է (ուստի ոչ երբեք, C): Եթե X = Y, դիսպերսիան 4 Var(X) է, ոչ գումարը (D):", "feedback_wrong_en": "It is not always true (A) - the covariance term matters. It often holds (so not never, C). If X = Y the variance is 4 Var(X), not the sum (D)."}, {"id": "PROB-08", "area": "probability", "module": "19", "difficulty": "3", "template": "misconception", "question_hy": "Ավտոբուսը գալիս է ըստ էքսպոնենցիալ բաշխման՝ 10 րոպե միջինով: Դու արդեն սպասել ես 10 րոպե: Ո՞րն է սպասվող լրացուցիչ սպասումը:", "question_en": "A bus arrives per an exponential distribution with mean 10 min. You have already waited 10 min. What is the expected additional wait?", "optA_hy": "0՝ այն պետք է հենց հիմա գա", "optA_en": "0 - it should arrive any second now", "optB_hy": "ևս մոտ 10 րոպե՝ էքսպոնենցիալ բաշխումը հիշողություն չունի", "optB_en": "about 10 more minutes - the exponential is memoryless", "optC_hy": "20 րոպե", "optC_en": "20 minutes", "optD_hy": "հնարավոր չէ որոշել", "optD_en": "it cannot be determined", "correct": "B", "points": "1", "feedback_correct_hy": "Էքսպոնենցիալ բաշխումը հիշողություն չունի. արդեն սպասած ժամանակը ոչ մի տեղեկություն չի տալիս մնացած սպասման մասին: Սպասվող լրացուցիչ ժամանակը դեռ ~10 րոպե է, կարծես նոր ես եկել:", "feedback_correct_en": "The exponential distribution is memoryless: the time already waited gives no information about the remaining wait. The expected additional time is still ~10 minutes, as if you just arrived.", "feedback_wrong_hy": "Ավելի երկար սպասելն այն չի դարձնում «սպասվող» (A, C ենթադրում են կուտակում): Հիշողություն չունենալով՝ լիովին որոշված է (D)՝ ևս մոտ 10 րոպե (B):", "feedback_wrong_en": "Waiting longer does not make it 'due' (A, C assume accumulation). It is fully determined by memorylessness (D): about 10 more minutes (B)."}, {"id": "PROB-09", "area": "probability", "module": "20", "difficulty": "2", "template": "compare", "question_hy": "Ո՞րն է տարբերությունը մեծ թվերի օրենքի (LLN) և կենտրոնական սահմանային թեորեմի (CLT) միջև:", "question_en": "What is the difference between the Law of Large Numbers (LLN) and the Central Limit Theorem (CLT)?", "optA_hy": "նրանք նույն բանն են ասում", "optA_en": "they say the same thing", "optB_hy": "LLN-ն ասում է, որ նմուշային միջինը զուգամիտում է իսկական միջինին, CLT-ն նկարագրում է նմուշային միջինի տատանումների ձևը (մոտավորապես նորմալ) դրա շուրջ", "optB_en": "LLN says the sample mean converges to the true mean; CLT describes the shape (approximately normal) of the sample mean's fluctuations around it", "optC_hy": "LLN-ն նորմալության մասին է, CLT-ն՝ զուգամիտության", "optC_en": "LLN is about normality; CLT is about convergence", "optD_hy": "երկուսն էլ կիրառվում են միայն նորմալ տվյալների համար", "optD_en": "both apply only to normal data", "correct": "B", "points": "1", "feedback_correct_hy": "LLN. նմուշային միջինը զուգամիտում է իսկական միջինին n-ի աճով (ուր է հասնում): CLT. ինչպես է հասնում՝ միջինի բաշխումը իսկության շուրջ դառնում է մոտավորապես նորմալ, ցրվածությունը նվազում է 1/sqrt(n)-ի պես:", "feedback_correct_en": "LLN: the sample mean converges to the true mean as n grows (where it lands). CLT: how it gets there - the mean's distribution around the truth becomes approximately normal, with spread shrinking like 1/sqrt(n).", "feedback_wrong_hy": "Նրանք տարբեր են (A) և C-ն շփոթում է դրանք: Երկուսն էլ կիրառվում են նորմալ տվյալներից շատ ավելի լայն (D)՝ դա է CLT-ի իմաստը: LLN=զուգամիտություն, CLT=ձև (B):", "feedback_wrong_en": "They are distinct (A) and C swaps them. Both apply far beyond normal data (D) - that is the point of the CLT. LLN=convergence, CLT=shape (B)."}, {"id": "PROB-10", "area": "probability", "module": "17", "difficulty": "2", "template": "misconception", "question_hy": "Ի՞նչ են տալիս Մարկովի և Չեբիշևի անհավասարությունները:", "question_en": "What do Markov's and Chebyshev's inequalities give you?", "optA_hy": "ցանկացած պատահույթի ճշգրիտ հավանականությունը", "optA_en": "the exact probability of any event", "optB_hy": "վերին գնահատականներ պոչային հավանականությունների վրա՝ օգտագործելով միայն միջինը (Մարկով) կամ միջինն ու դիսպերսիան (Չեբիշև), առանց բաշխման ձևի", "optB_en": "upper bounds on tail probabilities using only the mean (Markov) or mean and variance (Chebyshev), with no distribution shape needed", "optC_hy": "ցանկացած բաշխման միջինը", "optC_en": "the mean of any distribution", "optD_hy": "դրանք աշխատում են միայն նորմալ բաշխման համար", "optD_en": "they only work for the normal distribution", "correct": "B", "points": "1", "feedback_correct_hy": "Այս անհավասարությունները սահմանափակում են, թե որքան հավանականություն կարող է լինել պոչերում՝ օգտագործելով միայն միջինը (Մարկով) կամ միջին+դիսպերսիա (Չեբիշև)՝ առանց բաշխման ձևի: Դրանք թույլ են, բայց գրեթե ենթադրություն չեն պահանջում:", "feedback_correct_en": "These inequalities bound how much probability can sit in the tails using only the mean (Markov) or mean+variance (Chebyshev) - distribution-free. They are loose but require almost no assumptions.", "feedback_wrong_hy": "Դրանք տալիս են գնահատականներ, ոչ ճշգրիտ հավանականություններ (A) կամ բուն միջինը (C): Բաշխումից անկախ են, ոչ միայն նորմալ (D): Պոչային գնահատականներ մոմենտներից (B):", "feedback_wrong_en": "They give bounds, not exact probabilities (A) or the mean itself (C). They are distribution-free, not normal-only (D). Tail bounds from moments (B)."}, {"id": "STAT-01", "area": "statistics", "module": "24", "difficulty": "3", "template": "misconception", "question_hy": "Միջինի 95% վստահության միջակայքը ստացվել է [2.1, 4.8]: Ո՞ր մեկնաբանությունն է ճիշտ:", "question_en": "A 95% confidence interval for a mean comes out as [2.1, 4.8]. Which interpretation is correct?", "optA_hy": "Տվյալների 95%-ը ընկնում է [2.1, 4.8]-ում", "optA_en": "95% of the data lie in [2.1, 4.8]", "optB_hy": "95% հավանականությամբ իսկական միջինը [2.1, 4.8]-ում է", "optB_en": "there is a 95% probability the true mean is in [2.1, 4.8]", "optC_hy": "Եթե նմուշառումը կրկնեինք բազմիցս, այդպիսի միջակայքների մոտ 95%-ը կպարունակեր իսկական միջինը", "optC_en": "if we repeated the sampling many times, about 95% of such intervals would contain the true mean", "optD_hy": "Իսկական միջինը հաստատ այս միջակայքում է", "optD_en": "the true mean is definitely inside this interval", "correct": "C", "points": "1", "feedback_correct_hy": "Վստահության մակարդակը ընթացակարգի հատկություն է. բազմաթիվ կրկնված նմուշների վրա կառուցված միջակայքերի 95%-ը ներառում է իսկական միջինը: Մեկ ֆիքսված միջակայքի համար միջինը կա՛մ ներսում է, կա՛մ դրսում:", "feedback_correct_en": "A confidence level is a property of the procedure: across many repeated samples, 95% of the constructed intervals capture the true mean. For one fixed interval the mean is either in or out.", "feedback_wrong_hy": "A-ն շփոթում է վստահության միջակայքը տվյալների ցրվածության (կանխատեսման միջակայքի) հետ: B-ն բայեսյան սխալ ընթերցումն է՝ հաճախականության մոտեցմամբ միջինը ֆիքսված է, ոչ պատահական: D-ն չափազանցնում է մեկ միջակայքի վստահությունը:", "feedback_wrong_en": "A confuses the CI with the spread of the data (a prediction interval). B is the Bayesian misreading - the frequentist mean is fixed, not random. D overstates certainty for a single interval."}, {"id": "STAT-02", "area": "statistics", "module": "25", "difficulty": "3", "template": "misconception", "question_hy": "Հետազոտությունը հայտնում է p = 0.03: Ի՞նչ է նշանակում այս p-արժեքը:", "question_en": "A study reports p = 0.03. What does this p-value mean?", "optA_hy": "3% հավանականություն, որ զրոյական վարկածը ճիշտ է", "optA_en": "there is a 3% probability the null hypothesis is true", "optB_hy": "Ենթադրելով, որ զրոյականը ճիշտ է, 3% հավանականություն կա այսքան կամ ավելի ծայրահեղ տվյալների", "optB_en": "assuming the null is true, there is a 3% chance of data this extreme or more", "optC_hy": "97% հավանականություն, որ այլընտրանքային վարկածը ճիշտ է", "optC_en": "there is a 97% probability the alternative hypothesis is true", "optD_hy": "Էֆեկտը մեծ է և կարևոր", "optD_en": "the effect is large and important", "correct": "B", "points": "1", "feedback_correct_hy": "p-արժեքը P(այսքան ծայրահեղ տվյալներ | զրոյականը ճիշտ է) է: Հաշվվում է՝ ենթադրելով, որ H0-ն ճիշտ է. այն H0-ի (կամ H1-ի) ճիշտ լինելու հավանականությունը չէ և ոչինչ չի ասում էֆեկտի մեծության մասին:", "feedback_correct_en": "A p-value is P(data this extreme | null true). It is computed assuming H0 holds; it is not the probability that H0 (or H1) is true, and it says nothing about effect size.", "feedback_wrong_hy": "p-ն P(H0 ճիշտ) (A) կամ P(H1 ճիշտ) (C) չէ՝ դրանք պահանջում են նախնական բաշխումներ (Բայես): Փոքր p-ն կարող է ուղեկցվել չնչին, ոչ կարևոր էֆեկտով (D):", "feedback_wrong_en": "p is not P(H0 true) (A) or P(H1 true) (C) - those need priors (Bayes). A small p can come with a tiny, unimportant effect (D)."}, {"id": "STAT-03", "area": "statistics", "module": "25", "difficulty": "2", "template": "flaw", "question_hy": "Փաստարկ. «Մեր ստուգումը տվեց p = 0.4, որը բարձր է, ուստի մենք ապացուցեցինք, որ զրոյական վարկածը ճիշտ է»: Ի՞նչն է սխալ:", "question_en": "Argument: 'Our test gave p = 0.4, which is high, so we have proven the null hypothesis is true.' What is wrong?", "optA_hy": "Ոչինչ՝ բարձր p-արժեքը ապացուցում է զրոյականը", "optA_en": "nothing - a high p-value proves the null", "optB_hy": "H0-ը չմերժելը H0-ի ապացույց չէ. ապացույցի բացակայությունը բացակայության ապացույց չէ", "optB_en": "failing to reject H0 is not proof of H0; absence of evidence is not evidence of absence", "optC_hy": "Բարձր p-արժեքը նշանակում է, որ ստուգումը ձախողվեց", "optC_en": "a high p-value means the test failed", "optD_hy": "p = 0.4-ն իրականում վիճակագրորեն նշանակալի է", "optD_en": "p = 0.4 is actually statistically significant", "correct": "B", "points": "1", "feedback_correct_hy": "Բարձր p-արժեքը նշանակում է միայն, որ տվյալները համատեղելի են H0-ի հետ՝ գուցե էֆեկտը զրո է, գուցե ստուգումը բավարար հզորություն չուներ այն հայտնաբերելու: H0-ը երբեք չես ապացուցում, միայն չես մերժում:", "feedback_correct_en": "A high p-value just means the data are consistent with H0 - maybe the effect is zero, or maybe the test lacked power to detect it. You never prove H0, you only fail to reject it.", "feedback_wrong_hy": "Բարձր p-ն չի ապացուցում H0-ը (A): Ստուգումը չի ձախողվել (C): p = 0.4-ն սովորական մակարդակներում նշանակալի չէ, բայց ոչ նշանակալին նույնը չէ, ինչ ապացուցված զրոյականը (D):", "feedback_wrong_en": "High p does not prove H0 (A). The test did not fail (C). p = 0.4 is not significant at usual levels, but non-significant is not the same as proven-null (D)."}, {"id": "STAT-04", "area": "statistics", "module": "24", "difficulty": "2", "template": "misconception", "question_hy": "Ո՞րն է տարբերությունը ստանդարտ շեղման (SD) և միջինի ստանդարտ սխալի (SE) միջև:", "question_en": "What is the difference between the standard deviation (SD) and the standard error (SE) of the mean?", "optA_hy": "Նրանք նույն բանն են", "optA_en": "they are the same thing", "optB_hy": "SD-ն չափում է առանձին տվյալների ցրվածությունը, SE-ն՝ նմուշային միջինի ցրվածությունը և փոքրանում է n-ի աճով", "optB_en": "SD measures spread of individual data; SE measures spread of the sample mean and shrinks as n grows", "optC_hy": "SE-ն միշտ մեծ է SD-ից", "optC_en": "SE is always larger than SD", "optD_hy": "SD-ն փոքրանում է տվյալների ավելացմամբ, SE-ն՝ ոչ", "optD_en": "SD shrinks with more data, SE does not", "correct": "B", "points": "1", "feedback_correct_hy": "SD-ն նկարագրում է հենց տվյալների փոփոխականությունը և չի փոքրանում n-ով: SE = SD / sqrt(n) նկարագրում է, թե որքան ճշգրիտ է նմուշային միջինը գնահատում իսկական միջինը, և փոքրանում է n-ի աճով:", "feedback_correct_en": "SD describes the variability of the data itself and does not shrink with n. SE = SD / sqrt(n) describes how precisely the sample mean estimates the true mean, and it shrinks as n grows.", "feedback_wrong_hy": "Նրանք տարբեր են (A): SE = SD/sqrt(n) <= SD, ուստի SE-ն մեծ չէ (C): Հենց SE-ն, ոչ SD-ն, փոքրանում է n-ով (D):", "feedback_wrong_en": "They are different (A). SE = SD/sqrt(n) <= SD, so SE is not larger (C). It is SE, not SD, that shrinks with n (D)."}, {"id": "STAT-05", "area": "statistics", "module": "22", "difficulty": "3", "template": "misconception", "question_hy": "A գնահատականն անշեղ է, B-ն մի փոքր շեղված, բայց շատ ավելի ցածր դիսպերսիայով: Ո՞րն է անպայման ավելի լավը:", "question_en": "Estimator A is unbiased; estimator B is slightly biased but has much lower variance. Which is necessarily better?", "optA_hy": "A-ն, քանի որ անշեղ գնահատականները միշտ լավագույնն են", "optA_en": "A, because unbiased estimators are always best", "optB_hy": "Ոչ մեկն ինքնաբերաբար՝ ընդհանուր ճշգրտությունը MSE = շեղում^2 + դիսպերսիա է, ուստի շեղված ցածր-դիսպերսիա գնահատականը կարող է հաղթել", "optB_en": "neither automatically - accuracy is MSE = bias^2 + variance, so a biased low-variance estimator can win", "optC_hy": "B-ն միշտ, քանի որ միայն դիսպերսիան է կարևոր", "optC_en": "B always, because variance is all that matters", "optD_hy": "Նրանք պետք է ունենան նույն MSE-ն", "optD_en": "they must have identical MSE", "correct": "B", "points": "1", "feedback_correct_hy": "MSE = շեղում^2 + դիսպերսիա: Դիսպերսիան շատ իջեցնելը՝ քիչ շեղում ավելացնելով, կարող է նվազեցնել ընդհանուր սխալը: Այս շեղում-դիսպերսիա փոխզիջումն է պատճառը, որ շեղված գնահատականները (և ռեգուլյարիզացիան) հաճախ նախընտրելի են:", "feedback_correct_en": "MSE = bias^2 + variance. Lowering variance a lot while adding a little bias can reduce total error. This bias-variance tradeoff is why biased estimators (and regularization) are often preferred.", "feedback_wrong_hy": "Միայն անշեղությունը չի երաշխավորում ավելի ցածր սխալ (A)՝ դիսպերսիան նույնպես կարևոր է: Շեղումը նույնպես անկապ չէ (C): Նրանց MSE-ները ընդհանուր դեպքում տարբեր են (D):", "feedback_wrong_en": "Unbiasedness alone does not guarantee lower error (A) - variance counts too. Bias is not irrelevant either (C). Their MSEs generally differ (D)."}, {"id": "STAT-06", "area": "statistics", "module": "23", "difficulty": "3", "template": "misconception", "question_hy": "Ինչպե՞ս են կապված Maximum A Posteriori (MAP) և Maximum Likelihood (MLE) գնահատումները:", "question_en": "How are Maximum A Posteriori (MAP) and Maximum Likelihood (MLE) estimation related?", "optA_hy": "Նրանք միշտ տալիս են նույն գնահատականը", "optA_en": "they always give the same estimate", "optB_hy": "MAP-ն ճշմարտանմանությանն ավելացնում է նախնական բաշխում, հարթ (անտեղեկ) նախնականի դեպքում MAP-ը վերածվում է MLE-ի", "optB_en": "MAP adds a prior to the likelihood; with a flat (uninformative) prior, MAP reduces to MLE", "optC_hy": "MLE-ն օգտագործում է նախնական բաշխում, MAP-ը՝ ոչ", "optC_en": "MLE uses a prior, MAP does not", "optD_hy": "MAP-ն ընդհանրապես անտեսում է տվյալները", "optD_en": "MAP ignores the data entirely", "correct": "B", "points": "1", "feedback_correct_hy": "MAP-ը մաքսիմիզացնում է ճշմարտանմանություն × նախնական (հետին բաշխումը): Հարթ նախնականը դարձնում է նախնականը հաստատուն, ուստի MAP-ը և MLE-ն համընկնում են: Նախնականն է նաև կապում MAP-ը ռեգուլյարիզացիայի հետ:", "feedback_correct_en": "MAP maximizes likelihood times prior (the posterior). A flat prior makes the prior constant, so MAP and MLE coincide. The prior is also what connects MAP to regularization.", "feedback_wrong_hy": "Նրանք տարբերվում են, երբ նախնականը տեղեկատվական է (A): Հենց MAP-ն է, ոչ MLE-ն, օգտագործում նախնական (C): MAP-ն օգտագործում է և՛ տվյալները (ճշմարտանմանություն), և՛ նախնականը (D):", "feedback_wrong_en": "They differ when the prior is informative (A). It is MAP, not MLE, that uses a prior (C). MAP uses both the data (likelihood) and the prior (D)."}, {"id": "STAT-07", "area": "statistics", "module": "21", "difficulty": "3", "template": "flaw", "question_hy": "Բուժումը պլացեբոյից լավ է երևում տղամարդկանց մոտ, լավ է նաև կանանց մոտ, սակայն ընդհանուր առմամբ՝ ավելի վատ, երբ խմբերը միավորվում են: Ի՞նչ է կատարվում:", "question_en": "A treatment looks better than placebo in men, and better in women, yet worse overall when the groups are combined. What is going on?", "optA_hy": "Տվյալները պետք է հաշվային սխալ պարունակեն", "optA_en": "the data must contain an arithmetic error", "optB_hy": "Սիմփսոնի պարադոքս. ագրեգացված միտումը կարող է հակառակվել խմբային միտմանը՝ խառնող/խմբավորող փոփոխականի պատճառով", "optB_en": "Simpson's paradox: an aggregated trend can reverse a within-group trend due to a confounding/grouping variable", "optC_hy": "Դա անհնար է. խմբային միտումները միշտ պահպանվում են ամբողջի համար", "optC_en": "it is impossible; group trends always carry over to the whole", "optD_hy": "Դա ապացուցում է, որ բուժումը էֆեկտ չունի", "optD_en": "it proves the treatment has no effect", "correct": "B", "points": "1", "feedback_correct_hy": "Սա Սիմփսոնի պարադոքսն է: Անհավասար խմբերը և թաքնված փոփոխականը կարող են ստիպել միավորված համեմատությունը հակառակվել խմբերի ներսում հետևողական ուղղությանը: Ագրեգացումը կարող է մոլորեցնել:", "feedback_correct_en": "This is Simpson's paradox. Unequal group sizes and a lurking variable can make the combined comparison reverse the consistent within-group direction. Aggregation can mislead.", "feedback_wrong_hy": "Հաշվային սխալ պետք չէ (A)՝ սա իրական վիճակագրական երևույթ է: Խմբային միտումները միշտ չեն պահպանվում ագրեգացիայի ժամանակ (C): Չի ապացուցում էֆեկտի բացակայությունը (D)՝ խմբերի ներսի էֆեկտը կարող է ազնիվը լինել:", "feedback_wrong_en": "No arithmetic error is needed (A) - it is a real statistical phenomenon. Group trends do not always survive aggregation (C). It does not prove no effect (D); the within-group effect may be the honest one."}, {"id": "STAT-08", "area": "statistics", "module": "25", "difficulty": "2", "template": "misconception", "question_hy": "Թիմը կատարում է 20 անկախ ստուգում 0.05 նշանակալիության մակարդակով՝ առանց իրական էֆեկտի տվյալների վրա: Մոտավորապես քանի՞ կեղծ «նշանակալի» արդյունք պետք է սպասեն:", "question_en": "A team runs 20 independent tests at significance level 0.05 on data with no real effects. About how many false 'significant' results should they expect?", "optA_hy": "Զրո՝ 0.05-ը չափազանց փոքր է, որ նշանակություն ունենա", "optA_en": "zero - 0.05 is too small to matter", "optB_hy": "Մոտ 1, քանի որ ամեն ստուգում ունի 5% կեղծ-դրական հավանականություն (բազմակի համեմատությունների խնդիր)", "optB_en": "about 1, because each test has a 5% false-positive chance (multiple-comparisons problem)", "optC_hy": "Ճիշտ 20՝ բոլորը կլինեն նշանակալի", "optC_en": "exactly 20, all will be significant", "optD_hy": "Ընդհանրապես հնարավոր չէ կանխատեսել", "optD_en": "it cannot be predicted at all", "correct": "B", "points": "1", "feedback_correct_hy": "alpha = 0.05-ի դեպքում ամեն զրոյական ստուգում ունի 5% կեղծ-դրականի հավանականություն, ուստի 20 ստուգումը միջինում տալիս է 20 * 0.05 = 1 կեղծ նշանակալի արդյունք: Ահա թե ինչու է բազմակի ստուգումը պահանջում ուղղում (Bonferroni, BH):", "feedback_correct_en": "At alpha = 0.05, each null test has a 5% chance of a false positive, so 20 tests give on average 20 * 0.05 = 1 false significant result. This is why multiple testing needs correction (Bonferroni, BH).", "feedback_wrong_hy": "Կեղծ դրականները կուտակվում են, ուստի զրո չէ (A): Ոչ բոլոր 20-ը կլինեն նշանակալի (C): Սպասվող քանակը կանխատեսելի է՝ n * alpha (B, D):", "feedback_wrong_en": "False positives accumulate, so it is not zero (A). Not all 20 will be significant (C). The expected count is predictable: n * alpha (B, D)."}, {"id": "STAT-09", "area": "statistics", "module": "25", "difficulty": "3", "template": "misconception", "question_hy": "I տիպի և II տիպի սխալներն են, համապատասխանաբար...", "question_en": "A Type I error and a Type II error are, respectively...", "optA_hy": "ճիշտ զրոյականն ընդունելը, սխալ զրոյականը մերժելը", "optA_en": "accepting a true null; rejecting a false null", "optB_hy": "ճիշտ զրոյականը մերժելը (կեղծ դրական), սխալ զրոյականը չմերժելը (կեղծ բացասական)", "optB_en": "rejecting a true null (false positive); failing to reject a false null (false negative)", "optC_hy": "նույն սխալի երկու անուն", "optC_en": "two names for the same mistake", "optD_hy": "սխալներ, որ հնարավոր են միայն փոքր նմուշների դեպքում", "optD_en": "errors only possible with small samples", "correct": "B", "points": "1", "feedback_correct_hy": "I տիպ = ճիշտ H0-ը մերժել (կեղծ դրական, alpha մակարդակ): II տիպ = սխալ H0-ը չմերժել (կեղծ բացասական, beta): Հզորություն = 1 - beta՝ իրական էֆեկտը բռնելու հավանականությունը:", "feedback_correct_en": "Type I = rejecting a true H0 (false positive, rate alpha). Type II = failing to reject a false H0 (false negative, rate beta). Power = 1 - beta, the chance of catching a real effect.", "feedback_wrong_hy": "A-ն շրջված է: Դրանք տարբեր սխալներ են (C): Գոյություն ունեն ցանկացած նմուշի չափի դեպքում, թեև մեծ n-ը նվազեցնում է II տիպը (D): Կեղծ դրական ընդդեմ կեղծ բացասական (B):", "feedback_wrong_en": "A has it backwards. They are distinct errors (C). They exist at any sample size, though larger n reduces Type II (D). False positive vs false negative (B)."}, {"id": "STAT-10", "area": "statistics", "module": "24", "difficulty": "2", "template": "match", "question_hy": "Ի՞նչ է անում բուտստրապը (bootstrap):", "question_en": "What does the bootstrap do?", "optA_hy": "պոպուլյացիայից հավաքում է բոլորովին նոր, ավելի մեծ նմուշ", "optA_en": "it collects a brand-new larger sample from the population", "optB_hy": "գոյություն ունեցող տվյալները բազմիցս վերանմուշառում է փոխարինումով՝ գնահատելու վիճակագրի փոփոխականությունը (օրինակ՝ SE, վստահության միջակայք)", "optB_en": "it resamples the existing data with replacement many times to estimate the variability (e.g. SE, CI) of a statistic", "optC_hy": "ենթադրում է, որ տվյալները նորմալ են, և օգտագործում բանաձև", "optC_en": "it assumes the data is normal and uses a formula", "optD_hy": "հեռացնում է արտանետումները (outliers) տվյալներից", "optD_en": "it removes outliers from the data", "correct": "B", "points": "1", "feedback_correct_hy": "Բուտստրապը քո մեկ տվյալների հավաքածուն վերանմուշառում է փոխարինումով՝ նմանակելով բազմաթիվ «նոր» նմուշներ, ապա չափում, թե ինչպես է վիճակագիրը փոփոխվում դրանց միջև՝ տալով SE և վստահության միջակայքեր առանց բաշխման ենթադրությունների:", "feedback_correct_en": "The bootstrap resamples your one dataset with replacement to simulate many 'new' samples, then measures how the statistic varies across them - giving SEs and confidence intervals without distributional assumptions.", "feedback_wrong_hy": "Այն վերաօգտագործում է առկա տվյալները, ոչ նոր հավաքածու (A): Բաշխումից անկախ է, ոչ նորմալ բանաձև (C): Արտանետումների հեռացում չէ (D): Վերանմուշառում փոխարինումով (B):", "feedback_wrong_en": "It reuses existing data, not a new collection (A). It is distribution-free, not a normal formula (C). It is not outlier removal (D). Resample with replacement (B)."}, {"id": "INFO-01", "area": "info_theory", "module": "28", "difficulty": "2", "template": "misconception", "question_hy": "Կուլբակ-Լայբլերի դիվերգենցիայի KL(P || Q)-ի մասին ո՞ր պնդումն է ճիշտ:", "question_en": "Which statement about the Kullback-Leibler divergence KL(P || Q) is correct?", "optA_hy": "Այն սիմետրիկ է. KL(P||Q) = KL(Q||P)", "optA_en": "it is symmetric: KL(P||Q) = KL(Q||P)", "optB_hy": "Այն ընդհանուր դեպքում ասիմետրիկ է և >= 0, հավասար 0-ի միայն երբ P = Q", "optB_en": "it is generally asymmetric and >= 0, equal to 0 only when P = Q", "optC_hy": "Այն կարող է բացասական լինել", "optC_en": "it can be negative", "optD_hy": "Այն իսկական հեռավորություն է (մետրիկա)", "optD_en": "it is a true distance (a metric)", "correct": "B", "points": "1", "feedback_correct_hy": "KL >= 0 (Գիբսի անհավասարություն), զրո՝ այն և միայն այն դեպքում երբ P = Q, բայց KL(P||Q) != KL(Q||P) ընդհանուր դեպքում: Քանի որ ասիմետրիկ է և խախտում է եռանկյան անհավասարությունը, այն իսկական մետրիկա չէ:", "feedback_correct_en": "KL >= 0 (Gibbs' inequality), zero iff P = Q, but KL(P||Q) != KL(Q||P) in general. Because it is asymmetric and violates the triangle inequality, it is not a true metric.", "feedback_wrong_hy": "KL-ը սիմետրիկ չէ (A) և մետրիկա չէ (D): Երբեք բացասական չէ (C): Միայն ոչ բացասականությունն ու P=Q պայմանն են ճիշտ (B):", "feedback_wrong_en": "KL is not symmetric (A) and not a metric (D). It is never negative (C). Only nonnegativity and the P=Q condition are right (B)."}, {"id": "INFO-02", "area": "info_theory", "module": "28", "difficulty": "2", "template": "predict", "question_hy": "Ֆիքսված վերջավոր ելքերի բազմության վրա բոլոր բաշխումներից ո՞րն ունի ամենաբարձր Շենոնի էնտրոպիան:", "question_en": "Among all distributions over a fixed finite set of outcomes, which has the highest Shannon entropy?", "optA_hy": "մեկ ելքի վրա կենտրոնացածը", "optA_en": "the one concentrated on a single outcome", "optB_hy": "հավասարաչափ բաշխումը (բոլոր ելքերը հավասարահավանական)", "optB_en": "the uniform distribution (all outcomes equally likely)", "optC_hy": "ցանկացած ասիմետրիկ բաշխում", "optC_en": "any skewed distribution", "optD_hy": "էնտրոպիան նույնն է բոլորի համար", "optD_en": "entropy is the same for all of them", "correct": "B", "points": "1", "feedback_correct_hy": "Էնտրոպիան չափում է անորոշությունը. այն մաքսիմալ է, երբ ելքերը հավասարահավանական են (հավասարաչափ), և մինիմալ (զրո), երբ մեկ ելք հաստատ է: Սա մաքսիմալ էնտրոպիայի սկզբունքի հիմքն է:", "feedback_correct_en": "Entropy measures uncertainty; it is maximized when outcomes are equally likely (uniform) and minimized (zero) when one outcome is certain. This is the basis of the maximum-entropy principle.", "feedback_wrong_hy": "Մեկ հաստատ ելքը տալիս է զրո էնտրոպիա՝ մինիմումը (A): Ասիմետրիկ բաշխումներն ունեն մաքսիմալից պակաս էնտրոպիա (C): Էնտրոպիան ակնհայտորեն կախված է բաշխումից (D):", "feedback_wrong_en": "A single certain outcome gives zero entropy, the minimum (A). Skewed distributions have less than maximal entropy (C). Entropy clearly depends on the distribution (D)."}, {"id": "INFO-03", "area": "info_theory", "module": "28", "difficulty": "3", "template": "misconception", "question_hy": "Ինչո՞ւ է խաչաձև էնտրոպիայի կորստի մինիմիզացումը համարժեք ճշմարտանմանության մաքսիմիզացմանը:", "question_en": "Why is minimizing cross-entropy loss equivalent to maximizing likelihood?", "optA_hy": "Նրանք կապ չունեն. անունները պարզապես նման են", "optA_en": "they are unrelated; the names just sound similar", "optB_hy": "Խաչաձև էնտրոպիան հավասար է բացասական միջին լոգ-ճշմարտանմանությանը, ուստի մեկը մինիմիզացնելը մաքսիմիզացնում է մյուսը", "optB_en": "cross-entropy equals the negative average log-likelihood, so minimizing one maximizes the other", "optC_hy": "Միայն երբ տվյալները նորմալ բաշխված են", "optC_en": "only when the data is normally distributed", "optD_hy": "Ուսուցման ժամանակ խաչաձև էնտրոպիան մաքսիմիզացվում է, ոչ մինիմիզացվում", "optD_en": "cross-entropy is maximized, not minimized, in training", "correct": "B", "points": "1", "feedback_correct_hy": "Տվյալների և մոդելի միջև խաչաձև էնտրոպիան հավասար է բացասական միջին լոգ-ճշմարտանմանությանը (գումարած հաստատուն): Այն մինիմիզացնելը ճիշտ առավելագույն ճշմարտանմանությունն է՝ սա կապում է ինֆորմացիայի տեսությունը MLE-ի հետ:", "feedback_correct_en": "Cross-entropy between the data and the model equals the negative mean log-likelihood (plus a constant). Minimizing it is exactly maximum likelihood - this links information theory to MLE.", "feedback_wrong_hy": "Կապը ճշգրիտ է, ոչ պատահական (A), և գործում է նորմալ դեպքից դուրս (C): Ուսուցումը մինիմիզացնում է խաչաձև էնտրոպիան (D):", "feedback_wrong_en": "The link is exact, not coincidental (A), and holds beyond the normal case (C). Training minimizes cross-entropy (D)."}, {"id": "INFO-04", "area": "info_theory", "module": "29", "difficulty": "2", "template": "misconception", "question_hy": "Երկու մեծությունների միջև փոխադարձ ինֆորմացիան I(X; Y) հավասար է զրոյի հենց այն դեպքում, երբ...", "question_en": "Mutual information I(X; Y) between two variables equals zero exactly when...", "optA_hy": "X-ը և Y-ը կատարյալ կորելացված են", "optA_en": "X and Y are perfectly correlated", "optB_hy": "X-ը և Y-ը անկախ են", "optB_en": "X and Y are independent", "optC_hy": "X-ը հավասար է Y-ին", "optC_en": "X equals Y", "optD_hy": "X-ը և Y-ը երկուսն էլ հավասարաչափ են", "optD_en": "X and Y are both uniform", "correct": "B", "points": "1", "feedback_correct_hy": "Փոխադարձ ինֆորմացիան չափում է, թե որքանով մեկ մեծությունը իմանալը նվազեցնում է մյուսի անորոշությունը: Այն զրո է հենց երբ նրանք անկախ են, և մեծ՝ երբ ուժեղ կապված են:", "feedback_correct_en": "Mutual information measures how much knowing one variable reduces uncertainty about the other. It is zero exactly when they are independent, and large when strongly related.", "feedback_wrong_hy": "Կատարյալ կորելացիան (A) կամ X=Y-ը (C) տալիս են բարձր, ոչ զրո MI: Հավասարաչափ լինելը ոչինչ չի ասում նրանց կախվածության մասին (D): Զրո MI <=> անկախություն (B):", "feedback_wrong_en": "Perfect correlation (A) or X=Y (C) gives high, not zero, MI. Being uniform says nothing about their dependence (D). Zero MI <=> independence (B)."}, {"id": "CURSE-01", "area": "curse_dim", "module": "30", "difficulty": "3", "template": "predict", "question_hy": "Երբ չափողականությունների թիվը դառնում է շատ մեծ, ի՞նչ է պատահում պատահական կետերի միջև Էվկլիդեսյան հեռավորությունների հետ:", "question_en": "As the number of dimensions grows very large, what happens to Euclidean distances between random points?", "optA_hy": "մոտակա և ամենահեռու կետերը դառնում են գրեթե հավասար հեռու (հեռավորությունները կենտրոնանում են)", "optA_en": "the nearest and farthest points become almost equally distant (distances concentrate)", "optB_hy": "կետերը գնալով մոտենում են իրար", "optB_en": "points get closer and closer together", "optC_hy": "հեռավորությունները վարվում են ճիշտ ինչպես 2D-ում", "optC_en": "distances behave just like in 2D", "optD_hy": "մոտակա հարևանը դառնում է շատ ավելի մոտ, քան մնացածը", "optD_en": "the nearest neighbor becomes much closer than the rest", "correct": "A", "points": "1", "feedback_correct_hy": "Բարձր չափողականություններում մոտակա և ամենահեռու հեռավորությունների տարբերությունը կրճատվում է՝ դրանք կենտրոնանում են նման արժեքի շուրջ: Ահա թե ինչու են մոտակա հարևանի մեթոդները կորցնում իմաստը բարձր չափերում:", "feedback_correct_en": "In high dimensions the contrast between nearest and farthest distances shrinks - they concentrate around a similar value. This is why nearest-neighbor methods lose meaning in high-d.", "feedback_wrong_hy": "Կետերը պարզապես չեն փլվում իրար (B)՝ ավելի շուտ հարաբերական տարբերություններն անհետանում են: Բարձր-չափ վարքը շատ տարբեր է 2D ինտուիցիայից (C): Մոտակա հարևանը դադարում է առանձնանալ (D):", "feedback_wrong_en": "Points do not simply collapse together (B); rather the relative differences vanish. High-d behavior is very different from 2D intuition (C). The nearest neighbor stops standing out (D)."}, {"id": "CURSE-02", "area": "curse_dim", "module": "30", "difficulty": "2", "template": "misconception", "question_hy": "Ինչո՞ւ են տվյալները դառնում «նոսր» չափողականության աճով՝ վնասելով լոկալ հարևանությունների վրա հիմնված մեթոդներին:", "question_en": "Why does data become 'sparse' as dimensionality increases, hurting methods that rely on local neighborhoods?", "optA_hy": "համակարգիչները հիշողություն չեն բավականացնում", "optA_en": "computers run out of memory", "optB_hy": "տարածության ծավալը աճում է էքսպոնենցիալ, ուստի ֆիքսված թվով կետերը ծածկում են այն գնալով ավելի նոսր", "optB_en": "the volume of the space grows exponentially, so a fixed number of points covers it ever more thinly", "optC_hy": "տվյալների կետերը ժամանակի ընթացքում ֆիզիկապես հեռանում են", "optC_en": "the data points physically move apart over time", "optD_hy": "բարձր չափողականություններն ավելի քիչ կետ են պարունակում", "optD_en": "higher dimensions always contain fewer points", "correct": "B", "points": "1", "feedback_correct_hy": "Չափեր ավելացնելն էքսպոնենցիալ մեծացնում է ծավալը: Նույն խտությունը պահելու համար պետք կլիներ էքսպոնենցիալ ավելի շատ նմուշ, ուստի ցանկացած ֆիքսված տվյալների հավաքածու դառնում է նոսր, և լոկալ հարևանությունները՝ դատարկ:", "feedback_correct_en": "Adding dimensions blows up the volume exponentially. To keep the same density you would need exponentially more samples, so any fixed dataset becomes sparse and local neighborhoods empty out.", "feedback_wrong_hy": "Սա երկրաչափական փաստ է, ոչ սարքավորման սահմանափակում (A): Կետերը չեն շարժվում (C): Ոչ թե կետերն են քիչ, այլ նույն կետերը լցնում են շատ ավելի մեծ տարածություն (D):", "feedback_wrong_en": "It is a geometric fact, not a hardware limit (A). The points do not move (C). It is not that there are fewer points, but that the same points fill far more space (D)."}];

function buildForm() {
  var form = FormApp.create(FORM_TITLE);
  form.setDescription(FORM_DESCRIPTION);
  form.setIsQuiz(true);
  var currentArea = null, count = 0;
  for (var i = 0; i < ROWS.length; i++) {
    var r = ROWS[i];
    if (AREA_TITLES[r.area] === undefined) throw new Error(r.id + ': unknown area ' + r.area);
    if (r.area !== currentArea) {
      form.addPageBreakItem().setTitle(AREA_TITLES[r.area]);
      currentArea = r.area;
    }
    if (LETTERS.indexOf(r.correct) === -1) throw new Error(r.id + ': bad correct ' + r.correct);
    var item = form.addMultipleChoiceItem();
    item.setTitle((i + 1) + '. ' + r.question_hy + '\n' + r.question_en);
    item.setRequired(true);
    var choices = [];
    for (var c = 0; c < LETTERS.length; c++) {
      var L = LETTERS[c];
      choices.push(item.createChoice(r['opt' + L + '_hy'] + ' / ' + r['opt' + L + '_en'], L === r.correct));
    }
    item.setChoices(choices);
    item.setPoints(parseInt(r.points, 10) || 1);
    item.setFeedbackForCorrect(FormApp.createFeedback().setText(r.feedback_correct_hy + '\n\n' + r.feedback_correct_en).build());
    item.setFeedbackForIncorrect(FormApp.createFeedback().setText(r.feedback_wrong_hy + '\n\n' + r.feedback_wrong_en).build());
    count++;
  }
  Logger.log('Built ' + count + ' questions.');
  Logger.log('Edit URL: ' + form.getEditUrl());
  Logger.log('Published URL: ' + form.getPublishedUrl());
}
