var ROWS = [{"id": "PY-D-01", "area": "data_stack", "module": "libs02", "difficulty": "3", "template": "predict", "question": "a = np.array([1, 2, 3, 4]); b = a[1:3]; b[0] = 99. What is a afterward?", "optA": "[1, 2, 3, 4] (slicing makes a copy)", "optB": "[1, 99, 3, 4] (a NumPy slice is a view into the same data)", "optC": "an error", "optD": "[99, 2, 3, 4]", "correct": "B", "points": "1", "feedback_correct": "Unlike Python lists, a NumPy slice returns a view that shares memory with the original. Writing to the view writes to a. Use a[1:3].copy() for an independent array.", "feedback_wrong": "NumPy slicing does not copy (A) - that is list behavior. No error (C). The edited element is index 1 of a, giving [1,99,3,4] (B), not D."}, {"id": "PY-D-02", "area": "data_stack", "module": "libs02", "difficulty": "2", "template": "predict", "question": "a has shape (3, 1) and b has shape (1, 4). What is the shape of a + b?", "optA": "an error - the shapes do not match", "optB": "(3, 4) via broadcasting", "optC": "(3, 1)", "optD": "(1, 4)", "correct": "B", "points": "1", "feedback_correct": "Broadcasting stretches size-1 dimensions to match: (3,1) and (1,4) combine to (3,4). Dimensions are compatible when they are equal or one of them is 1.", "feedback_wrong": "Broadcastable shapes do not error (A). The result expands both, not keeping either original (C, D). It becomes (3,4) (B)."}, {"id": "PY-D-03", "area": "data_stack", "module": "libs02", "difficulty": "2", "template": "misconception", "question": "Why is a vectorized NumPy operation usually far faster than an equivalent Python for-loop?", "optA": "NumPy uses more CPU cores by default", "optB": "the loop runs in optimized compiled C over contiguous typed memory, avoiding per-element Python overhead", "optC": "NumPy caches the result", "optD": "Python loops are artificially slowed down", "correct": "B", "points": "1", "feedback_correct": "Vectorized ops push the loop into compiled C over a typed, contiguous array, skipping the per-iteration interpreter overhead of a Python loop. Same work, far less overhead.", "feedback_wrong": "It is not multicore by default (A) or caching (C). Python loops are not throttled (D); they are just interpreted per element (B)."}, {"id": "PY-D-04", "area": "data_stack", "module": "libs02", "difficulty": "2", "template": "misconception", "question": "For a 2D array M, what does M.sum(axis=0) compute?", "optA": "the sum of every element", "optB": "it collapses axis 0 (down the rows), giving one value per column", "optC": "one value per row", "optD": "the sum along the diagonal", "correct": "B", "points": "1", "feedback_correct": "axis=0 means 'collapse the row axis', so you sum down each column and get one number per column. axis=1 collapses columns, giving one per row.", "feedback_wrong": "That is sum() with no axis (A). axis=0 gives a per-column result, not per-row (C). It is not a diagonal sum (D)."}, {"id": "PY-D-05", "area": "data_stack", "module": "libs03", "difficulty": "2", "template": "match", "question": "What is the difference between df.loc[...] and df.iloc[...]?", "optA": "they are aliases", "optB": "loc selects by label (index/column names); iloc selects by integer position", "optC": "loc is by position; iloc is by label", "optD": "loc is for rows only; iloc is for columns only", "correct": "B", "points": "1", "feedback_correct": "loc is label-based (uses index and column names, end-inclusive); iloc is integer-position-based (end-exclusive). Mixing them up is a top Pandas bug.", "feedback_wrong": "They are not aliases (A) and C swaps them. Both can address rows and columns (D). loc=label, iloc=position (B)."}, {"id": "PY-D-06", "area": "data_stack", "module": "libs03", "difficulty": "3", "template": "flaw", "question": "A student writes df[df.a > 0]['b'] = 5 and is surprised df is unchanged (with a warning). What is the flaw?", "optA": "the comparison df.a > 0 is wrong", "optB": "chained indexing may assign to a temporary copy, so the write never reaches df; use df.loc[df.a > 0, 'b'] = 5", "optC": "you cannot assign to a DataFrame at all", "optD": "column 'b' must be numeric", "correct": "B", "points": "1", "feedback_correct": "Chained indexing (two [] in a row) can return a copy, so the assignment lands on that throwaway, not df - hence SettingWithCopyWarning. Do it in one step with .loc.", "feedback_wrong": "The filter is fine (A). DataFrames are assignable (C) and dtype is not the issue (D). The bug is chained indexing hitting a copy (B)."}, {"id": "PY-D-07", "area": "data_stack", "module": "libs03", "difficulty": "2", "template": "match", "question": "What does df.groupby('city')['sales'].mean() do conceptually?", "optA": "sorts the rows by city", "optB": "splits rows by city, computes the mean of sales within each group, then combines (split-apply-combine)", "optC": "drops the city column", "optD": "returns the single overall mean of sales", "correct": "B", "points": "1", "feedback_correct": "groupby follows split-apply-combine: split rows into groups by the key, apply the aggregation (mean) per group, and combine into one result per city.", "feedback_wrong": "It groups, not merely sorts (A). It does not drop columns (C) or give one overall mean (D); it is per-group (B)."}, {"id": "PY-D-08", "area": "data_stack", "module": "libs03", "difficulty": "2", "template": "misconception", "question": "In NumPy/Pandas, what is the result of np.nan == np.nan?", "optA": "True", "optB": "False - NaN is not equal to anything, including itself", "optC": "it raises an error", "optD": "NaN", "correct": "B", "points": "1", "feedback_correct": "By IEEE-754, NaN does not equal anything, even itself, so np.nan == np.nan is False. To detect NaN use np.isnan(x) or pd.isna(x), never ==.", "feedback_wrong": "NaN never equals itself (A). It returns a bool, not an error (C) or NaN (D). Use isna/isnan to test (B)."}, {"id": "PY-D-09", "area": "data_stack", "module": "libs02", "difficulty": "2", "template": "predict", "question": "a = np.array([1, 2, 3]); b = np.array([1, 0, 3]). What does a == b give?", "optA": "a single True or False", "optB": "an element-wise boolean array: array([True, False, True])", "optC": "an error", "optD": "the number of matching elements", "correct": "B", "points": "1", "feedback_correct": "Array comparisons are element-wise and return a boolean array. To reduce to one answer use (a == b).all() or .any(); putting the array directly in an if raises 'ambiguous truth value'.", "feedback_wrong": "It does not collapse to one bool (A) or a count (D). It does not error here (C); it returns the per-element mask (B)."}, {"id": "PY-D-10", "area": "data_stack", "module": "libs06", "difficulty": "2", "template": "match", "question": "Why use fig, ax = plt.subplots() and ax.plot(...) instead of plt.plot(...)?", "optA": "it is required; plt.plot does not exist", "optB": "the object-oriented fig/ax API gives explicit control over multiple subplots and is clearer for complex figures", "optC": "ax.plot is faster", "optD": "plt.plot cannot draw lines", "correct": "B", "points": "1", "feedback_correct": "The fig/ax (object-oriented) API makes each Axes explicit, which scales cleanly to subplots and fine control. plt.* works on the 'current' axes implicitly - fine for quick one-off plots.", "feedback_wrong": "plt.plot exists (A) and can draw lines (D). It is about clarity/control, not speed (C). The OO API is preferred for non-trivial figures (B)."}, {"id": "PY-D-11", "area": "data_stack", "module": "libs04", "difficulty": "2", "template": "predict", "question": "pd.merge(left, right, on='id') with no 'how' argument - which rows are kept?", "optA": "all rows from both tables", "optB": "only ids present in BOTH tables (inner join is the default)", "optC": "all rows from left only", "optD": "it raises without an explicit how", "correct": "B", "points": "1", "feedback_correct": "merge defaults to how='inner', keeping only keys found in both frames. Use how='left'/'right'/'outer' to keep unmatched rows (filled with NaN).", "feedback_wrong": "It does not keep everything (A - that is outer) or left-only (C - that is left). It does not require how (D). Default is inner (B)."}, {"id": "PY-D-12", "area": "data_stack", "module": "libs03", "difficulty": "2", "template": "misconception", "question": "Your DataFrame has NaNs, yet df.mean() returns numbers. Why, and what do dropna/fillna do?", "optA": "mean errors on NaN, so the numbers are wrong", "optB": "pandas skips NaN in aggregations by default; dropna removes missing rows/cols, fillna replaces them with a value", "optC": "NaNs are counted as zero in the mean", "optD": "you must always dropna before any operation", "correct": "B", "points": "1", "feedback_correct": "Most pandas aggregations skip NaN by default (so mean ignores them, not treats them as 0). dropna drops missing entries; fillna substitutes (0, a mean, forward-fill, etc.). Choose deliberately.", "feedback_wrong": "mean does not error (A) or treat NaN as 0 (C) - that would change the result. You do not always need dropna first (D); aggregations handle NaN (B)."}, {"id": "PY-D-13", "area": "data_stack", "module": "libs03", "difficulty": "2", "template": "compare", "question": "For an elementwise numeric transform on a big DataFrame column, which is usually preferred?", "optA": "df['x'].apply(a python function), because apply is always fastest", "optB": "a vectorized op like df['x'] * 2 or np.log(df['x']), which is much faster than per-row apply", "optC": "a Python for-loop over the rows", "optD": "df.iterrows()", "correct": "B", "points": "1", "feedback_correct": "Vectorized column operations run in optimized C over the whole array. apply (and especially iterrows/for-loops) call Python per element/row and are far slower. Reach for vectorization first.", "feedback_wrong": "apply is not the fastest (A); it is per-element Python. Explicit loops (C) and iterrows (D) are the slowest. Vectorize (B)."}, {"id": "PY-D-14", "area": "data_stack", "module": "libs02", "difficulty": "2", "template": "misconception", "question": "a = np.array([1, 2, 3]) has dtype int64. You do a[0] = 3.7. What is a[0]?", "optA": "3.7", "optB": "3 - the float is truncated to fit the integer dtype of the array", "optC": "it raises a type error", "optD": "the whole array becomes float", "correct": "B", "points": "1", "feedback_correct": "A NumPy array has a fixed dtype. Assigning 3.7 into an int array truncates to 3; the array does not change dtype per element. Create a float array if you need decimals.", "feedback_wrong": "It does not store 3.7 (A) or convert the array (D). It does not error (C); it silently truncates to 3 (B) - a real gotcha."}, {"id": "PY-D-15", "area": "data_stack", "module": "libs02", "difficulty": "3", "template": "predict", "question": "a is a NumPy array. b = a[[0, 2]] (fancy indexing with a list); b[0] = 99. Does a change?", "optA": "yes, like a slice it is a view", "optB": "no - fancy indexing (with a list/array of indices) returns a copy, not a view", "optC": "it raises an error", "optD": "only if a is 2D", "correct": "B", "points": "1", "feedback_correct": "Basic slicing (a[0:2]) returns a view; fancy indexing (a[[0,2]] or boolean masks) returns a copy. So writing to b does not affect a here. View-vs-copy depends on the index type.", "feedback_wrong": "Fancy indexing copies, unlike a slice (A). No error (C), and it does not depend on dimensionality (D). a is unchanged (B)."}, {"id": "PY-D-16", "area": "data_stack", "module": "libs02", "difficulty": "1", "template": "misconception", "question": "Why call np.random.seed(509) (or use a Generator with a fixed seed) before generating random numbers?", "optA": "to make the numbers more random", "optB": "to make results reproducible - the same seed yields the same 'random' sequence every run", "optC": "it makes generation faster", "optD": "it is required or NumPy errors", "correct": "B", "points": "1", "feedback_correct": "Seeding fixes the pseudo-random sequence so runs are reproducible (key for experiments and debugging). It does not improve randomness or speed; without it NumPy just picks an unpredictable seed.", "feedback_wrong": "It does not increase randomness (A) or speed (C), and it is optional (D). Its purpose is reproducibility (B)."}, {"id": "PY-E-01", "area": "engineering", "module": "libs08", "difficulty": "1", "template": "match", "question": "Why use the logging module with levels (DEBUG/INFO/WARNING/ERROR) instead of print?", "optA": "print is broken in scripts", "optB": "levels let you filter and route messages by severity and toggle detail without deleting code", "optC": "logging is always faster than print", "optD": "print cannot display text", "correct": "B", "points": "1", "feedback_correct": "Logging adds severity levels, formatting, and handlers (file + console) so you can control verbosity centrally and keep diagnostics in production - things print cannot do cleanly.", "feedback_wrong": "print is not broken (A) and can show text (D). Logging is not chosen for raw speed (C); it is for leveled, routable, configurable output (B)."}, {"id": "PY-E-02", "area": "engineering", "module": "libs10", "difficulty": "3", "template": "compare", "question": "For a CPU-bound task (heavy number crunching) in CPython, which usually gives real speedup, and why?", "optA": "threading, because threads always run in parallel", "optB": "multiprocessing, because the GIL stops threads from running Python bytecode truly in parallel", "optC": "neither can ever speed anything up", "optD": "threading, because it uses less memory", "correct": "B", "points": "1", "feedback_correct": "CPython's GIL lets only one thread execute Python bytecode at a time, so threads do not speed up CPU-bound work. Separate processes sidestep the GIL. Threads still help for I/O-bound work.", "feedback_wrong": "Threads do not run Python bytecode in parallel under the GIL (A). Processes can help CPU-bound work (C). Memory is not the deciding factor (D)."}, {"id": "PY-E-03", "area": "engineering", "module": "libs09", "difficulty": "2", "template": "match", "question": "What is a pytest fixture for?", "optA": "asserting that a test passes", "optB": "providing reusable setup (and teardown) - e.g. a temp file or sample data - injected into tests", "optC": "skipping a test", "optD": "measuring code coverage", "correct": "B", "points": "1", "feedback_correct": "Fixtures supply prepared state (data, connections, temp dirs) to tests and can clean up afterward, keeping tests DRY and isolated. A test requests one by naming it as an argument.", "feedback_wrong": "Asserting uses assert (A). Skipping uses markers (C). Coverage is a separate tool (D). Fixtures are reusable setup/teardown (B)."}, {"id": "PY-E-04", "area": "engineering", "module": "libs09", "difficulty": "1", "template": "misconception", "question": "In pytest, how do you check an expected result inside a test?", "optA": "return the value from the test function", "optB": "use a plain assert statement; pytest reports a helpful failure if it is False", "optC": "print the value and read it by eye", "optD": "wrap everything in try/except", "correct": "B", "points": "1", "feedback_correct": "pytest uses plain assert and rewrites it to show a useful message on failure. A test passes if no assertion fails and no exception escapes; return values are ignored.", "feedback_wrong": "Return values are ignored (A). Printing is not a check (C). You do not need try/except for normal assertions (D); just assert (B)."}, {"id": "PY-E-05", "area": "engineering", "module": "libs10", "difficulty": "2", "template": "flaw", "question": "You fetch a page with requests + BeautifulSoup, but the data visible in the browser is missing from what you parsed. The most likely reason?", "optA": "BeautifulSoup is broken", "optB": "the content is rendered by JavaScript after load, which requests does not execute", "optC": "the site has no HTML at all", "optD": "you must always use multiprocessing to scrape", "correct": "B", "points": "1", "feedback_correct": "requests fetches the raw HTML response; it does not run JavaScript. Content injected by JS after load is not in that HTML. Use a browser driver (Selenium/Playwright) or a backing API.", "feedback_wrong": "BeautifulSoup parses what it is given (A). The page has HTML, just not the JS-built parts (C). Multiprocessing is unrelated (D). JS rendering is the cause (B)."}, {"id": "PY-E-06", "area": "engineering", "module": "libs10", "difficulty": "2", "template": "misconception", "question": "Adding multiprocessing to a small, fast task sometimes makes it slower. Why?", "optA": "multiprocessing is always slower", "optB": "spawning processes and serializing data between them has overhead that can exceed the work saved", "optC": "the GIL blocks separate processes", "optD": "small tasks cannot be parallelized at all", "correct": "B", "points": "1", "feedback_correct": "Process startup and inter-process data serialization (pickling) cost time. For small or quick tasks that overhead can dwarf the gains, so a plain loop wins. Parallelism pays off when the work per item is large.", "feedback_wrong": "It is not always slower (A) - it helps big CPU-bound jobs. The GIL does not block separate processes (C). Small tasks can be parallelized, just often not worth it (D)."}, {"id": "PY-E-07", "area": "engineering", "module": "libs09", "difficulty": "2", "template": "match", "question": "What does @pytest.mark.parametrize do?", "optA": "runs a test in parallel", "optB": "runs the same test function once per set of input/expected values, reporting each case separately", "optC": "marks a test to be skipped", "optD": "measures the parameters' memory use", "correct": "B", "points": "1", "feedback_correct": "parametrize feeds multiple (input, expected) cases into one test function, each reported as its own pass/fail. It replaces copy-pasting near-identical tests.", "feedback_wrong": "It is not about parallelism (A), skipping (C), or memory (D). It multiplies one test over many cases (B)."}, {"id": "PY-E-08", "area": "engineering", "module": "libs09", "difficulty": "2", "template": "match", "question": "How do you assert that a function raises ValueError on bad input, in pytest?", "optA": "wrap it in try/except and pass if it crashes", "optB": "use 'with pytest.raises(ValueError):' around the call", "optC": "assert that the function returns an error", "optD": "you cannot test for exceptions", "correct": "B", "points": "1", "feedback_correct": "with pytest.raises(ValueError): asserts the block raises that exception (and fails the test if it does not). Cleaner and more precise than a manual try/except.", "feedback_wrong": "Manual try/except is clumsy and easy to get wrong (A). Functions raise, not return, exceptions (C). Exceptions are testable (D)."}, {"id": "PY-E-09", "area": "engineering", "module": "libs10", "difficulty": "2", "template": "predict", "question": "For a task that mostly waits on network/disk (I/O-bound), does threading help in CPython despite the GIL?", "optA": "no, the GIL blocks everything", "optB": "yes - threads release the GIL while waiting on I/O, so they overlap the waiting time effectively", "optC": "only multiprocessing ever helps", "optD": "threading only helps CPU-bound work", "correct": "B", "points": "1", "feedback_correct": "The GIL is released during blocking I/O, so threads can overlap their waits - great for I/O-bound work (many requests, file reads). The GIL only blocks parallel CPU-bound Python execution.", "feedback_wrong": "The GIL does not block during I/O waits (A). Processes are not the only option (C). Threading helps I/O-bound, not CPU-bound, work (D - reversed)."}, {"id": "PY-E-10", "area": "engineering", "module": "libs08", "difficulty": "2", "template": "misconception", "question": "With a fresh logger at default settings, log.info('hi') shows nothing. Why?", "optA": "info messages are broken", "optB": "the default level is WARNING, so INFO and DEBUG are filtered out until you lower the level", "optC": "you must restart Python", "optD": "logging requires a file to write to", "correct": "B", "points": "1", "feedback_correct": "The default level is WARNING, so INFO/DEBUG are suppressed until you configure a lower level (e.g. logging.basicConfig(level=logging.INFO)). Nothing is broken; it is just filtered.", "feedback_wrong": "INFO works once enabled (A). No restart needed (C) and no file required (D). The default WARNING threshold hides INFO (B)."}, {"id": "PY-E-11", "area": "engineering", "module": "libs08", "difficulty": "1", "template": "match", "question": "What problem do argparse / click / typer solve?", "optA": "they speed up the program", "optB": "they parse command-line arguments into typed values, with help text and validation, instead of manually reading sys.argv", "optC": "they replace functions", "optD": "they are only for web servers", "correct": "B", "points": "1", "feedback_correct": "CLI libraries turn command-line flags/args into structured, validated, documented inputs (--name, --count) so you do not hand-parse sys.argv. typer/click also add types and auto-generated help.", "feedback_wrong": "They are about argument parsing, not speed (A), not replacing functions (C), and not web-only (D)."}, {"id": "PY-E-12", "area": "engineering", "module": "libs09", "difficulty": "2", "template": "match", "question": "In a unit test, why 'mock' an external API call?", "optA": "to make the real call faster", "optB": "to replace the slow/unreliable external dependency with a controlled fake, so the test is fast, deterministic, and offline", "optC": "because real calls are illegal in tests", "optD": "mocking tests the external API itself", "correct": "B", "points": "1", "feedback_correct": "Mocking substitutes a fake for an external dependency (network, DB, clock), so the unit test runs fast and deterministically and tests your code, not the third party. You assert how the mock was called.", "feedback_wrong": "It does not speed up the real call (A) - it avoids it. Real calls are not illegal, just undesirable in unit tests (C). It tests your code, not the API (D)."}, {"id": "PY-B-01", "area": "backend_modern", "module": "libs12", "difficulty": "2", "template": "predict", "question": "Some customers have no orders. SELECT ... FROM customers LEFT JOIN orders ... vs INNER JOIN: what is the key difference?", "optA": "no difference", "optB": "LEFT JOIN keeps all customers (NULLs where no order); INNER JOIN keeps only customers that have orders", "optC": "INNER JOIN keeps all customers; LEFT JOIN drops the unmatched", "optD": "LEFT JOIN only works on numeric columns", "correct": "B", "points": "1", "feedback_correct": "LEFT JOIN returns every left-table row, filling NULLs where there is no match. INNER JOIN returns only rows matched on both sides, dropping order-less customers.", "feedback_wrong": "There is a real difference (A) and C reverses it. Join type does not depend on column type (D). LEFT keeps unmatched left rows (B)."}, {"id": "PY-B-02", "area": "backend_modern", "module": "libs12", "difficulty": "2", "template": "misconception", "question": "In SQL, what is the difference between WHERE and HAVING?", "optA": "they are the same", "optB": "WHERE filters rows before grouping; HAVING filters groups after GROUP BY and can use aggregates", "optC": "HAVING runs before WHERE", "optD": "WHERE can use aggregate functions like COUNT(*)", "correct": "B", "points": "1", "feedback_correct": "WHERE filters individual rows before aggregation; HAVING filters grouped results after GROUP BY and can reference aggregates like COUNT(*). Order: WHERE, then GROUP BY, then HAVING.", "feedback_wrong": "They differ (A) and HAVING comes after WHERE, not before (C). WHERE cannot use aggregates (D) - that is what HAVING is for (B)."}, {"id": "PY-B-03", "area": "backend_modern", "module": "libs13", "difficulty": "2", "template": "misconception", "question": "You define a Pydantic model with field age: int and pass age='30' (a string). What happens by default?", "optA": "it raises immediately because the type is wrong", "optB": "Pydantic validates and coerces '30' to the int 30", "optC": "it stores the string '30' unchanged", "optD": "the field is set to None", "correct": "B", "points": "1", "feedback_correct": "Pydantic validates input against the declared types and coerces compatible values, so '30' becomes 30. Genuinely invalid input (e.g. 'abc') raises a ValidationError.", "feedback_wrong": "Coercible input does not immediately raise (A). It does not keep the raw string (C) or null it (D); it converts to int (B)."}, {"id": "PY-B-04", "area": "backend_modern", "module": "libs15", "difficulty": "2", "template": "match", "question": "In FastAPI, what do you get by declaring a request body as a Pydantic model?", "optA": "nothing automatic; you parse the JSON yourself", "optB": "automatic request parsing, type validation, and OpenAPI docs generated from the model", "optC": "the endpoint becomes synchronous only", "optD": "the model replaces the database", "correct": "B", "points": "1", "feedback_correct": "FastAPI uses the Pydantic model to parse and validate the incoming JSON and to auto-generate the OpenAPI/Swagger schema. An invalid body gets a clear 422 automatically.", "feedback_wrong": "You do not hand-parse (A). It does not force sync (C) or act as a database (D). It gives validation plus docs for free (B)."}, {"id": "PY-B-05", "area": "backend_modern", "module": "libs14", "difficulty": "1", "template": "match", "question": "Why prefer pathlib (Path('data') / 'file.csv') over manual string concatenation for file paths?", "optA": "it is only shorter to type", "optB": "it builds correct paths across operating systems and offers methods like .exists(), .suffix, .parent", "optC": "it makes files load faster", "optD": "strings cannot represent paths", "correct": "B", "points": "1", "feedback_correct": "pathlib handles OS-specific separators correctly and gives path-aware methods (exists, suffix, parent, glob), avoiding fragile concatenation like 'a' + '/' + 'b'.", "feedback_wrong": "It is more than brevity (A). It does not affect load speed (C). Strings can hold paths but are error-prone across OSes (D); pathlib is safer (B)."}, {"id": "PY-B-06", "area": "backend_modern", "module": "libs12", "difficulty": "3", "template": "misconception", "question": "A column has some NULLs. What does COUNT(col) return, and how does col = NULL behave?", "optA": "COUNT(col) counts all rows; col = NULL finds the NULLs", "optB": "COUNT(col) skips NULLs; and col = NULL never matches - you must use col IS NULL", "optC": "COUNT(col) errors on NULLs", "optD": "NULL equals NULL, so col = NULL works fine", "correct": "B", "points": "1", "feedback_correct": "COUNT(col) counts only non-NULL values (use COUNT(*) for all rows). NULL means 'unknown', so any = comparison yields unknown, never true - you must use IS NULL / IS NOT NULL.", "feedback_wrong": "COUNT(col) excludes NULLs, so A is wrong, and it does not error (C). NULL = NULL is not true (D); test with IS NULL (B)."}, {"id": "PY-B-07", "area": "backend_modern", "module": "libs12", "difficulty": "2", "template": "misconception", "question": "In standard SQL, 'SELECT city, name FROM t GROUP BY city' is usually an error. Why?", "optA": "you cannot GROUP BY a text column", "optB": "every selected column must be in GROUP BY or wrapped in an aggregate; 'name' is neither", "optC": "GROUP BY must come before SELECT", "optD": "you can only group by one column", "correct": "B", "points": "1", "feedback_correct": "When you group, each output row represents a group, so non-grouped columns must be aggregated (MAX, COUNT, ...) - otherwise which 'name' would it show? Add name to GROUP BY or aggregate it.", "feedback_wrong": "You can group by text (A). SELECT is written first regardless (C). You can group by multiple columns (D). The rule is grouped-or-aggregated (B)."}, {"id": "PY-B-08", "area": "backend_modern", "module": "libs12", "difficulty": "3", "template": "match", "question": "You want each row plus a rank within its category, WITHOUT collapsing rows. Which SQL tool fits?", "optA": "GROUP BY category", "optB": "a window function: RANK() OVER (PARTITION BY category ORDER BY ...)", "optC": "WHERE category = ...", "optD": "DISTINCT", "correct": "B", "points": "1", "feedback_correct": "Window functions (OVER / PARTITION BY) compute across a group of rows while keeping every row - perfect for ranks, running totals, moving averages. GROUP BY would collapse the rows.", "feedback_wrong": "GROUP BY collapses rows (A). WHERE filters (C); DISTINCT dedups (D). To keep rows and add a per-group rank, use a window function (B)."}, {"id": "PY-B-09", "area": "backend_modern", "module": "libs13", "difficulty": "2", "template": "match", "question": "Beyond type coercion, what does a Pydantic field validator let you do?", "optA": "nothing extra", "optB": "enforce custom rules (e.g. value must be positive, email must contain @) and raise on violation", "optC": "speed up the model", "optD": "connect to a database", "correct": "B", "points": "1", "feedback_correct": "Validators run custom logic per field (or across fields), letting you enforce domain rules beyond type checks and raise a ValidationError when they fail. They express business constraints.", "feedback_wrong": "They add real capability (A), not speed (C) or DB access (D). They enforce custom rules (B)."}, {"id": "PY-B-10", "area": "backend_modern", "module": "libs15", "difficulty": "2", "template": "misconception", "question": "When should a FastAPI endpoint be 'async def' rather than 'def'?", "optA": "always - async is strictly better", "optB": "when it awaits non-blocking I/O (async DB/HTTP clients); a plain def is fine and runs in a threadpool for blocking work", "optC": "never - FastAPI does not support async", "optD": "only for GET requests", "correct": "B", "points": "1", "feedback_correct": "Use async def when you await truly non-blocking I/O. If you call blocking libraries, a normal def (which FastAPI runs in a threadpool) avoids blocking the event loop. async is not automatically faster.", "feedback_wrong": "async is not always better (A) - blocking code in async def stalls the loop. FastAPI fully supports async (C). It is unrelated to the HTTP method (D)."}, {"id": "PY-B-11", "area": "backend_modern", "module": "libs12", "difficulty": "2", "template": "misconception", "question": "Why build queries with parameters (e.g. execute('... WHERE id = ?', (uid,))) instead of f-string concatenation?", "optA": "it is shorter", "optB": "it prevents SQL injection - user input is sent as data, not executable SQL", "optC": "parameters make queries run faster only", "optD": "f-strings do not work with SQL", "correct": "B", "points": "1", "feedback_correct": "Parameterized queries pass user input as data the driver escapes, so a malicious value cannot alter the query. Formatting user input straight into SQL is the classic injection vulnerability.", "feedback_wrong": "It is about security, not brevity (A) or speed alone (C). f-strings 'work' but are dangerous here (D). Parameterization prevents injection (B)."}, {"id": "PY-B-12", "area": "backend_modern", "module": "libs18", "difficulty": "2", "template": "misconception", "question": "What does the Single Responsibility Principle say a module or class should have?", "optA": "only one method", "optB": "one reason to change - it should do one well-defined job, not mix unrelated concerns", "optC": "no dependencies at all", "optD": "exactly one attribute", "correct": "B", "points": "1", "feedback_correct": "SRP: a unit should have one reason to change, i.e. one cohesive responsibility. Mixing parsing + I/O + business logic in one class makes it fragile; split concerns so each can change independently.", "feedback_wrong": "It is not about a literal single method (A) or attribute (D), nor zero dependencies (C). It is one reason to change / one responsibility (B)."}];

function buildForm() {
  var form = FormApp.create(FORM_TITLE);
  form.setDescription(FORM_DESCRIPTION);
  form.setIsQuiz(true);
  var currentArea = null, count = 0;
  for (var i = 0; i < ROWS.length; i++) {
    var r = ROWS[i];
    if (AREA_TITLES[r.area] === undefined) throw new Error(r.id + ': unknown area ' + r.area);
    if (r.area !== currentArea) {
      form.addPageBreakItem().setTitle(AREA_TITLES[r.area]);
      currentArea = r.area;
    }
    if (LETTERS.indexOf(r.correct) === -1) throw new Error(r.id + ': bad correct ' + r.correct);
    var item = form.addMultipleChoiceItem();
    item.setTitle((i + 1) + '. ' + r.question);
    item.setRequired(true);
    var choices = [];
    for (var c = 0; c < LETTERS.length; c++) {
      var L = LETTERS[c];
      choices.push(item.createChoice(r['opt' + L], L === r.correct));
    }
    item.setChoices(choices);
    item.setPoints(parseInt(r.points, 10) || 1);
    item.setFeedbackForCorrect(FormApp.createFeedback().setText(r.feedback_correct).build());
    item.setFeedbackForIncorrect(FormApp.createFeedback().setText(r.feedback_wrong).build());
    count++;
  }
  Logger.log('Built ' + count + ' questions.');
  Logger.log('Edit URL: ' + form.getEditUrl());
  Logger.log('Published URL: ' + form.getPublishedUrl());
}
